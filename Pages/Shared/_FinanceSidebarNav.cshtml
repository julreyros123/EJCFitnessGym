@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var currentOperatingView = Context.Request.Query["view"].ToString();
    var logoutReturnUrl = "/Identity/Account/BackOfficeLogin";

    var isOperatingExpensesPath = currentPath.StartsWith("/Finance/OperatingExpenses", StringComparison.OrdinalIgnoreCase);
    var isOperatingAddView = isOperatingExpensesPath &&
        (string.IsNullOrWhiteSpace(currentOperatingView) || string.Equals(currentOperatingView, "add", StringComparison.OrdinalIgnoreCase));
    var isOperatingRecordsView = isOperatingExpensesPath &&
        string.Equals(currentOperatingView, "records", StringComparison.OrdinalIgnoreCase);

    string ActiveIfPrefix(params string[] prefixes)
    {
        foreach (var prefix in prefixes)
        {
            if (currentPath.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
        }

        return string.Empty;
    }
}

<nav class="ejc-admin-nav" aria-label="Finance navigation">
    <div class="ejc-admin-nav-group">
        <span class="ejc-admin-nav-section">Finance Modules</span>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/Dashboard")" asp-page="/Finance/Dashboard" title="Dashboard">
            <i class="bi bi-speedometer2"></i>
            <span class="ejc-admin-nav-text">Dashboard</span>
        </a>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/WeeklySalesAudit")" asp-page="/Finance/WeeklySalesAudit" title="Weekly Sales Audit">
            <i class="bi bi-clipboard2-check"></i>
            <span class="ejc-admin-nav-text">Weekly Sales Audit</span>
        </a>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/FundRequests")" asp-page="/Finance/FundRequests" title="Fund Queue">
            <i class="bi bi-cash-stack"></i>
            <span class="ejc-admin-nav-text">Fund Queue</span>
        </a>
        <details class="ejc-admin-nav-module" @(isOperatingExpensesPath ? "open" : null)>
            <summary class="ejc-admin-nav-module-trigger" title="Operating Expenses">
                <i class="bi bi-wallet-fill"></i>
                <span class="ejc-admin-nav-text">Operating Expenses</span>
                <i class="bi bi-chevron-down ejc-admin-nav-module-caret" aria-hidden="true"></i>
            </summary>
            <div class="ejc-admin-nav-module-links">
                <a class="ejc-admin-nav-link ejc-admin-nav-link-sub @(isOperatingAddView ? "active" : string.Empty)"
                   asp-page="/Finance/OperatingExpenses"
                   asp-route-view="add"
                   title="Add Operating Expense">
                    <i class="bi bi-plus-circle"></i>
                    <span class="ejc-admin-nav-text">Add Expense</span>
                </a>
                <a class="ejc-admin-nav-link ejc-admin-nav-link-sub @(isOperatingRecordsView ? "active" : string.Empty)"
                   asp-page="/Finance/OperatingExpenses"
                   asp-route-view="records"
                   title="Expense Records">
                    <i class="bi bi-table"></i>
                    <span class="ejc-admin-nav-text">Expense Records</span>
                </a>
            </div>
        </details>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/RevenueProfit")" asp-page="/Finance/RevenueProfit" title="Revenue & Profit">
            <i class="bi bi-graph-up-arrow"></i>
            <span class="ejc-admin-nav-text">Revenue &amp; Profit</span>
        </a>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/NetForecast")" asp-page="/Finance/NetForecast" title="Net Forecast">
            <i class="bi bi-calculator-fill"></i>
            <span class="ejc-admin-nav-text">Net Forecast</span>
        </a>
        <a class="ejc-admin-nav-link @ActiveIfPrefix("/Finance/GeneralLedger")" asp-page="/Finance/GeneralLedger" title="General Ledger">
            <i class="bi bi-journal-bookmark-fill"></i>
            <span class="ejc-admin-nav-text">General Ledger</span>
        </a>
    </div>

    <div class="ejc-admin-nav-divider"></div>

    <div class="ejc-admin-nav-group">
        <form class="ejc-admin-nav-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@logoutReturnUrl">
            <button type="submit" class="ejc-admin-nav-link ejc-admin-nav-link-button" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span class="ejc-admin-nav-text">Logout</span>
            </button>
        </form>
    </div>
</nav>
