@page
@model EJCFitnessGym.Pages.Staff.AttendanceModel
@{
    ViewData["Title"] = "Attendance";
}

<div class="py-4">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Analytics</span>
            <h1 class="h2 mb-1">Attendance Monitor</h1>
            <p class="ejc-muted mb-0">Review today’s sessions. Manual check-out is optional and stale sessions auto-close after @Model.AutoCheckoutHours hours.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <span class="ejc-muted small">On Floor</span>
                    <h2 class="h3 mb-0">@Model.OnFloorCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <span class="ejc-muted small">Closed Today (Manual + Auto)</span>
                    <h2 class="h3 mb-0">@Model.CompletedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <span class="ejc-muted small">Plan Expiring (<=3 days)</span>
                    <h2 class="h3 mb-0">@Model.PlanExpiringCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h5 class="mb-0">Daily Attendance Log</h5>
            <span class="text-muted small">Today</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Rows.Count == 0)
            {
                <div class="p-4">
                    <p class="ejc-muted mb-0">No attendance sessions recorded yet for this branch today.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Check-In (local)</th>
                                <th>Check-Out (local)</th>
                                <th>Duration</th>
                                <th>Attendance</th>
                                <th>Membership</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                <tr>
                                    <td>@row.MemberDisplayName</td>
                                    <td class="text-nowrap">@row.CheckInUtc.ToLocalTime().ToString("MMMM d, yyyy h:mm tt")</td>
                                    <td class="text-nowrap">@(row.CheckOutUtc.HasValue ? row.CheckOutUtc.Value.ToLocalTime().ToString("MMMM d, yyyy h:mm tt") : "-")</td>
                                    <td class="text-nowrap">@row.DurationLabel</td>
                                    <td><span class="@row.StatusBadgeClass">@row.StatusLabel</span></td>
                                    <td><span class="@row.MembershipStatusBadgeClass">@row.MembershipStatusLabel</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
