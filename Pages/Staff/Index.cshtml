@page
@model EJCFitnessGym.Pages.Staff.IndexModel
@{
    ViewData["Title"] = "Front Desk Home";
}

<div class="py-4 ejc-staff-home-page">
    <div class="ejc-page-header mb-4">
        <div>
            <span class="ejc-eyebrow">Front Desk</span>
            <h1 class="h2 mb-1">Front Desk Home</h1>
            <p class="ejc-muted mb-1">Start with one task, complete it fast, then move to the next queue.</p>
            <small class="text-muted">@Model.ScopeLabel</small>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Quick Actions</h2>
            <span class="small text-muted">Core front-desk flow</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <a class="card h-100 text-decoration-none text-reset ejc-staff-action-card" asp-page="/Staff/CheckIn">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <i class="bi bi-person-check-fill fs-4 text-primary"></i>
                                <span class="badge text-bg-primary">Step 1</span>
                            </div>
                            <h3 class="h6">Check-In / Check-Out</h3>
                            <p class="small text-muted mb-0">Scan QR or search member, then record attendance.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a class="card h-100 text-decoration-none text-reset ejc-staff-action-card" asp-page="/Staff/PlanStatus">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <i class="bi bi-card-checklist fs-4 text-warning"></i>
                                <span class="badge text-bg-warning text-dark">Step 2</span>
                            </div>
                            <h3 class="h6">Billing & Plan</h3>
                            <p class="small text-muted mb-0">Verify renewals, due dates, and payment status.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a class="card h-100 text-decoration-none text-reset ejc-staff-action-card" asp-page="/Staff/SuppliesPayments">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <i class="bi bi-cash-coin fs-4 text-success"></i>
                                <span class="badge text-bg-success">Step 3</span>
                            </div>
                            <h3 class="h6">POS & Stock Requests</h3>
                            <p class="small text-muted mb-0">Sell products or submit restock requests. Admin confirms official stock-in later.</p>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a class="card h-100 text-decoration-none text-reset ejc-staff-action-card" asp-page="/Staff/CommunicationHub">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <i class="bi bi-telephone-forward-fill fs-4 text-info"></i>
                                <span class="badge text-bg-info">Step 4</span>
                            </div>
                            <h3 class="h6">Member Follow-Ups</h3>
                            <p class="small text-muted mb-0">Queue reminders for due invoices and expiring plans.</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">On Floor Now</div>
                    <div class="display-6 fw-semibold mb-0">@Model.OnFloorNow</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Due / Overdue Invoices (3 days)</div>
                    <div class="display-6 fw-semibold mb-0">@Model.DueSoonInvoiceCount</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Pending PayMongo Payments</div>
                    <div class="display-6 fw-semibold mb-0">@Model.PendingPayMongoPaymentCount</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Open Replacement Requests</div>
                    <div class="display-6 fw-semibold mb-0">@Model.OpenReplacementRequestCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <div class="small text-muted">Sales Today</div>
                <div class="h4 mb-0">PHP @Model.ProductSalesTodayAmount.ToString("N2")</div>
                <div class="small text-muted">@Model.ProductSalesTodayCount completed sale(s)</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary btn-sm" asp-page="/Staff/SuppliesPayments">Open POS & Requests</a>
                <a class="btn btn-outline-primary btn-sm" asp-page="/Staff/SuppliesPayments" asp-route-panel="payments">View Receipts</a>
                <a class="btn btn-outline-primary btn-sm" asp-page="/Staff/SuppliesPayments" asp-route-panel="supply">Request Stock</a>
                <a class="btn btn-outline-primary btn-sm" asp-page="/Staff/Reports">Open Reports</a>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0">Recent Attendance Events</h2>
                    <span class="small text-muted">Latest first</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.RecentAttendance.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-muted mb-0">No recent attendance events yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Time (local)</th>
                                        <th>Member</th>
                                        <th>Event</th>
                                        <th>Branch</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.RecentAttendance)
                                    {
                                        <tr>
                                            <td class="text-nowrap">@row.TimeLocal.ToString("MMMM d, yyyy h:mm tt")</td>
                                            <td>@row.MemberDisplayName</td>
                                            <td><span class="@row.EventBadgeClass">@row.EventLabel</span></td>
                                            <td>@(string.IsNullOrWhiteSpace(row.BranchId) ? "-" : row.BranchId)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h6 mb-0">Secondary Tools</h2>
                </div>
                <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-page="/Staff/Attendance">
                        Attendance Monitor
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-page="/Staff/Reports">
                        Daily Reports
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-page="/Staff/ActivityLogs">
                        Activity Logs
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" asp-page="/Staff/ReplacementRequests">
                        Replacements
                        <i class="bi bi-chevron-right small"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
