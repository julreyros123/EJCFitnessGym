@page
@using System.Globalization
@model EJCFitnessGym.Pages.Staff.ReportsModel
@{
    ViewData["Title"] = "Staff Reports";
    var peso = CultureInfo.GetCultureInfo("en-PH");
}

<div class="py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Staff Reports</h1>
            <p class="text-muted mb-0">Front-desk operational report for the last 7 days.</p>
            <small class="text-muted">@Model.ScopeLabel</small>
        </div>
        <div class="text-end">
            <small class="text-muted d-block">Coverage</small>
            <strong>@Model.PeriodStartUtc.ToLocalTime().ToString("MMM dd") - @DateTime.UtcNow.ToLocalTime().ToString("MMM dd, yyyy")</strong>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Check-Ins</div>
                    <div class="fs-4 fw-bold">@Model.CheckInCount</div>
                    <div class="small text-muted">@Model.CheckOutCount check-out(s)</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Auto Check-Outs</div>
                    <div class="fs-4 fw-bold">@Model.AutoCheckOutCount</div>
                    <div class="small text-muted">Session timeout closures</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Product Sales</div>
                    <div class="fs-4 fw-bold">@Model.ProductSalesAmount.ToString("C0", peso)</div>
                    <div class="small text-muted">@Model.ProductSalesCount completed sale(s)</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Follow-Up Queue</div>
                    <div class="fs-4 fw-bold">@Model.PendingReplacementCount</div>
                    <div class="small text-muted">@Model.ExpiringPlanCount plan(s) expiring in 7 days</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-8">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h6 mb-0">Daily Operations</h2>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Check-Ins</th>
                                    <th>Check-Outs</th>
                                    <th>Sales</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.DailyRows)
                                {
                                    <tr>
                                        <td>@row.DateUtc.ToLocalTime().ToString("ddd, MMM dd")</td>
                                        <td>@row.CheckIns</td>
                                        <td>@row.CheckOuts</td>
                                        <td>@row.SalesAmount.ToString("C0", peso)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h6 mb-0">Handoff Actions</h2>
                </div>
                <div class="card-body d-grid gap-2">
                    <a class="btn btn-outline-primary text-start" asp-page="/Staff/CheckIn">Open Check-In Desk</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Staff/SuppliesPayments">Record Product Sales</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Staff/SuppliesPayments" asp-route-panel="supply">Submit Stock Request</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Staff/ReplacementRequests">Send Replacement Request</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Staff/CommunicationHub">Queue Member Reminders</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Finance/WeeklySalesAudit">Forward to Finance Audit</a>
                </div>
            </div>
        </div>
    </div>
</div>
