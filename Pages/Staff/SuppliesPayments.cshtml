@page
@model EJCFitnessGym.Pages.Staff.SuppliesPaymentsModel
@using EJCFitnessGym.Models.Inventory
@{
    ViewData["Title"] = "POS & Stock Requests";
    var subtotal = Model.CartTotal;
    var vatAmount = Math.Round(subtotal * 0.12m, 2, MidpointRounding.AwayFromZero);
    var grandTotal = subtotal + vatAmount;
    var paymentsButtonClass = Model.ShowPaymentsPanel ? "btn-primary" : "btn-outline-primary";
    var supplyButtonClass = Model.ShowSupplyPanel ? "btn-primary" : "btn-outline-primary";
}

<div class="pt-2 pb-3 ejc-pos-page">
    @if (TempData["Success"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }

    @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <div class="ejc-page-header mb-3">
        <div>
            <span class="ejc-eyebrow">Front Desk</span>
            <h1 class="h3 mb-1">POS & Stock Requests</h1>
            <p class="ejc-muted mb-0">Sell stocked products or submit restock requests. Official stock-in happens after admin confirms delivery.</p>
        </div>
    </div>

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-sm @paymentsButtonClass"
               asp-page="/Staff/SuppliesPayments"
               asp-route-panel="payments">
                Product Sales
            </a>
            <a class="btn btn-sm @supplyButtonClass"
               asp-page="/Staff/SuppliesPayments"
               asp-route-panel="supply">
                Request Stock
            </a>
            @if (Model.ShowPaymentsPanel || Model.ShowSupplyPanel)
            {
                <a class="btn btn-sm btn-outline-secondary"
                   asp-page="/Staff/SuppliesPayments">
                    Back To Sales
                </a>
            }
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="submit" form="pos-checkout-form" class="btn btn-sm btn-primary">Complete Sale</button>
            <a class="btn btn-sm btn-outline-primary"
               asp-page="/Staff/SuppliesPayments"
               asp-route-panel="payments">
                View Receipts
            </a>
        </div>
    </div>

    <div class="row g-4 align-items-start mb-4">
        <div class="col-12 col-lg-7 col-xl-8">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Available Products</h5>
                    <span class="text-muted small">@Model.RetailProducts.Count items</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 ejc-staff-table ejc-product-catalog-table">
                            <colgroup>
                                <col style="width: 36%;" />
                                <col style="width: 22%;" />
                                <col style="width: 14%;" />
                                <col style="width: 14%;" />
                                <col style="width: 14%;" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Category</th>
                                    <th class="text-end">Price</th>
                                    <th class="text-end">Stock</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model.RetailProducts)
                                {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td>
                                            <span class="badge bg-secondary">@product.Category</span>
                                        </td>
                                        <td class="text-end">PHP @product.UnitPrice.ToString("N2")</td>
                                        <td class="text-end">
                                            <span class="ejc-pos-stock @(product.IsLowStock ? "is-low" : string.Empty)">
                                                @product.Stock @product.Unit
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <form method="post" asp-page-handler="AddToCart" class="d-inline">
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Add</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5 col-xl-4">
            <div class="ejc-pos-sticky-stack">
                <div class="card mb-4">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h5 class="mb-0">Checkout Summary</h5>
                        <span class="text-muted small">@Model.CartItemCount items</span>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive mb-3 ejc-pos-cart-wrap">
                            <table class="table table-sm align-middle mb-0 ejc-staff-table ejc-sale-cart-table"
                                   data-ejc-paginate-disabled="true">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Subtotal</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.CurrentSaleLines.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-3">Cart is empty.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var line in Model.CurrentSaleLines)
                                        {
                                            <tr>
                                                <td>@line.ProductName</td>
                                                <td class="text-end text-nowrap">
                                                    <form method="post" asp-page-handler="UpdateQuantity" class="d-inline-flex align-items-center gap-1">
                                                        <input type="hidden" name="productId" value="@line.ProductId" />
                                                        <input type="number"
                                                               name="quantity"
                                                               value="@line.Quantity"
                                                               min="0"
                                                               class="form-control form-control-sm"
                                                               style="width: 70px;" />
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                                    </form>
                                                </td>
                                                <td class="text-end text-nowrap">PHP @line.LineTotal.ToString("N2")</td>
                                                <td class="text-end text-nowrap">
                                                    <form method="post" asp-page-handler="RemoveFromCart" class="d-inline">
                                                        <input type="hidden" name="productId" value="@line.ProductId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="ejc-pos-totals">
                            <div class="ejc-pos-total-row">
                                <span>Subtotal</span>
                                <strong>PHP @subtotal.ToString("N2")</strong>
                            </div>
                            <div class="ejc-pos-total-row">
                                <span>VAT (12%)</span>
                                <strong>PHP @vatAmount.ToString("N2")</strong>
                            </div>
                            <div class="ejc-pos-total-row is-grand">
                                <span>Total Due</span>
                                <strong>PHP @grandTotal.ToString("N2")</strong>
                            </div>
                        </div>

                        <form method="post" asp-page-handler="CompleteSale" id="pos-checkout-form" class="mt-3">
                            <div class="mb-2">
                                <label class="form-label">Customer Name (optional)</label>
                                <input type="text" name="customerName" class="form-control" placeholder="Walk-in customer" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Payment Method</label>
                                <select name="paymentMethod" class="form-select">
                                    <option value="Cash">Cash</option>
                                    <option value="GCash">GCash</option>
                                    <option value="Card">Card</option>
                                    <option value="Maya">Maya</option>
                                    <option value="BankTransfer">Bank Transfer</option>
                                    <option value="ChargeToAccount">Charge to Account</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Complete Sale</button>
                        </form>

                        <div class="row g-2 mt-3">
                            <div class="col-6">
                                <form method="post" asp-page-handler="ClearCart">
                                    <button type="submit" class="btn btn-outline-secondary w-100"
                                            onclick="return confirm('Clear all items from this cart?');">
                                        Clear Cart
                                    </button>
                                </form>
                            </div>
                            <div class="col-6">
                                <a class="btn btn-outline-primary w-100"
                                   asp-page="/Staff/SuppliesPayments"
                                   asp-route-panel="payments">
                                    Receipts
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @if (Model.ShowPaymentsPanel)
    {
        <div class="card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Recent Product Payments</h5>
                <span class="text-muted small">Today</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0 ejc-staff-table ejc-product-payments-table"
                           data-ejc-page-size="8"
                           data-ejc-search-placeholder="Search receipt, customer, method, or status">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Receipt #</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Method</th>
                                <th class="text-end text-nowrap">Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.RecentSales)
                            {
                                <tr>
                                    <td>@payment.Time</td>
                                    <td>@payment.ReceiptNo</td>
                                    <td>@payment.Customer</td>
                                    <td>@payment.Items</td>
                                    <td>@payment.Method</td>
                                    <td class="text-end text-nowrap">PHP @payment.Amount.ToString("N2")</td>
                                    <td><span class="@SuppliesPaymentsModel.PaymentStatusBadge(payment.Status)">@payment.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.ShowSupplyPanel)
    {
        <div class="alert alert-info mb-4" role="alert">
            <div class="fw-semibold mb-1">Role split</div>
            <div class="small">
                Staff submits the request. Admin approves and confirms the physical stock-in. Finance records the supplier cost and final audit.
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-xl-4">
                <div class="card h-100">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h5 class="mb-0">Create Stock Request</h5>
                        <span class="text-muted small">Staff step</span>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="CreateSupplyRequest" class="row g-3">
                            <div class="col-12">
                                <label for="stockRequestItemName" class="form-label">Item Name</label>
                                <input id="stockRequestItemName"
                                       type="text"
                                       name="itemName"
                                       class="form-control"
                                       placeholder="Example: Whey protein 5lb"
                                       required />
                            </div>
                            <div class="col-md-6">
                                <label for="stockRequestCategory" class="form-label">Category</label>
                                <input id="stockRequestCategory"
                                       type="text"
                                       name="category"
                                       class="form-control"
                                       placeholder="Supplements / Drinks / Supplies" />
                            </div>
                            <div class="col-md-6">
                                <label for="stockRequestUnit" class="form-label">Unit</label>
                                <select id="stockRequestUnit" name="unit" class="form-select">
                                    <option value="piece">piece</option>
                                    <option value="box">box</option>
                                    <option value="pack">pack</option>
                                    <option value="set">set</option>
                                    <option value="bottle">bottle</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="stockRequestQuantity" class="form-label">Requested Quantity</label>
                                <input id="stockRequestQuantity"
                                       type="number"
                                       name="quantity"
                                       min="1"
                                       value="1"
                                       class="form-control"
                                       required />
                            </div>
                            <div class="col-md-6">
                                <label for="stockRequestEstimatedCost" class="form-label">Estimated Unit Cost</label>
                                <input id="stockRequestEstimatedCost"
                                       type="number"
                                       name="estimatedCost"
                                       min="0"
                                       step="0.01"
                                       class="form-control"
                                       placeholder="0.00" />
                            </div>
                            <div class="col-12">
                                <div class="small text-muted">
                                    This form does not increase stock yet. Use it for products and consumables only. Equipment assets are recorded separately by finance.
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">Submit Request</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-xl-8">
                <div class="card h-100">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h5 class="mb-0">Recent Stock Requests</h5>
                        <span class="text-muted small">Request only, no stock-in yet</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0 ejc-staff-table"
                                   data-ejc-page-size="6"
                                   data-ejc-search-placeholder="Search request, item, branch, stage, or owner">
                                <thead>
                                    <tr>
                                        <th>Request #</th>
                                        <th>Branch</th>
                                        <th>Item</th>
                                        <th>Qty</th>
                                        <th>Stage</th>
                                        <th>Owner</th>
                                        <th>Next Owner</th>
                                        <th class="text-nowrap">Updated</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.SupplyRequests.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center text-muted py-3">No stock requests yet.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var request in Model.SupplyRequests)
                                        {
                                            <tr>
                                                <td>@request.RequestNo</td>
                                                <td>@request.Branch</td>
                                                <td>@request.Item</td>
                                                <td class="text-nowrap">@request.Quantity</td>
                                                <td><span class="@SuppliesPaymentsModel.SupplyStageBadge(request.Stage)">@request.Stage</span></td>
                                                <td><span class="@SuppliesPaymentsModel.SupplyRoleBadge(request.CurrentOwner)">@request.CurrentOwner</span></td>
                                                <td><span class="@SuppliesPaymentsModel.SupplyRoleBadge(request.NextOwner)">@request.NextOwner</span></td>
                                                <td class="text-nowrap">@request.UpdatedAt</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
