@page
@model EJCFitnessGym.Pages.Staff.CheckInModel
@{
    ViewData["Title"] = "Check-In / Out";
}

<div class="py-4">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Front Desk</span>
            <h1 class="h2 mb-1">Member Check-In Desk</h1>
            <p class="ejc-muted mb-0">Step 1: Find the member. Step 2: Confirm details. Step 3: Record check-in or check-out.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert @(Model.StatusIsError ? "alert-danger" : "alert-success") mb-4">@Model.StatusMessage</div>
    }

    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Step 1: Find Member</h5>
                    <span class="text-muted small">Scan or search</span>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Search" data-ejc-checkin-search-form>
                        <div class="row g-3 align-items-end">
                            <div class="col-md-9">
                                <label class="form-label">Member ID / Account Code / Name / Email / QR Value</label>
                                <input asp-for="SearchTerm" class="form-control" placeholder="Example: 6-digit code, member name, email, or scanned QR value" />
                                <div class="form-text">Tip: you can scan QR first, then the member profile loads automatically.</div>
                            </div>
                            <div class="col-md-3 d-grid">
                                <button type="submit" class="btn btn-primary">Search</button>
                            </div>
                        </div>
                    </form>
                    <div class="border rounded p-3 mt-3">
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                            <div>
                                <div class="fw-semibold">QR Scanner</div>
                                <div class="small text-muted">Scan member QR from phone or printed card for fast lookup.</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button id="start-qr-scan" type="button" class="btn btn-sm btn-outline-primary">Start Scanner</button>
                                <button id="stop-qr-scan" type="button" class="btn btn-sm btn-outline-secondary" disabled>Stop</button>
                            </div>
                        </div>
                        <div id="checkin-qr-reader" class="mt-3"></div>
                        <div id="checkin-qr-status" class="small text-muted mt-2">Scanner is off.</div>
                    </div>

                    @if (Model.SelectedMember is not null)
                    {
                        var member = Model.SelectedMember;
                        var membershipEndLocal = member.MembershipEndDateUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm zzz") ?? "-";
                        var nextBillingLocal = member.NextBillingDateUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm zzz") ?? "-";
                        var canCheckIn = member.HasActiveMembership && !member.HasPendingPayMongoPayment;

                        <div class="border rounded p-3 mt-4">
                            <div class="d-flex flex-wrap justify-content-between gap-3">
                                <div>
                                    <h6 class="mb-1">Step 2: Confirm Member</h6>
                                    <div class="fw-semibold">@member.MemberDisplayName</div>
                                    <div class="text-muted small">@member.Email</div>
                                </div>
                                <div class="d-flex gap-2">
                                    <form method="post" asp-page-handler="CheckIn">
                                        <input type="hidden" asp-for="SearchTerm" />
                                        <input type="hidden" asp-for="MemberUserId" value="@member.MemberUserId" />
                                        <button type="submit"
                                                class="btn btn-primary"
                                                disabled="@(!canCheckIn)"
                                                title="@(canCheckIn ? "Record member check-in." : "Resolve membership/payment issue before check-in.")">
                                            Check In
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="CheckOut">
                                        <input type="hidden" asp-for="SearchTerm" />
                                        <input type="hidden" asp-for="MemberUserId" value="@member.MemberUserId" />
                                        <button type="submit" class="btn btn-outline-primary">Check Out</button>
                                    </form>
                                </div>
                            </div>

                            <div class="row g-2 mt-2 small">
                                <div class="col-md-4"><span class="text-muted">Plan:</span> @member.PlanName</div>
                                <div class="col-md-4"><span class="text-muted">Plan Status:</span> @member.SubscriptionStatus</div>
                                <div class="col-md-4"><span class="text-muted">Membership Ends:</span> @membershipEndLocal</div>
                                <div class="col-md-4"><span class="text-muted">Next Billing:</span> @nextBillingLocal</div>
                                <div class="col-md-4"><span class="text-muted">Outstanding:</span> PHP @member.OutstandingBalance.ToString("N2")</div>
                                <div class="col-md-4">
                                    <span class="text-muted">Pending Online Payment:</span>
                                    <span class="badge @(member.HasPendingPayMongoPayment ? "bg-warning text-dark" : "bg-success")">
                                        @(member.HasPendingPayMongoPayment ? "Yes" : "None")
                                    </span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-muted">Membership Active:</span>
                                    <span class="badge @(member.HasActiveMembership ? "ejc-badge" : "bg-warning text-dark")">
                                        @(member.HasActiveMembership ? "Yes" : "No")
                                    </span>
                                </div>
                                <div class="col-md-4">
                                    <span class="text-muted">Check-In Allowed:</span>
                                    <span class="badge @(canCheckIn ? "bg-success" : "bg-danger")">
                                        @(canCheckIn ? "Yes" : "No")
                                    </span>
                                </div>
                            </div>

                            @if (!member.HasActiveMembership)
                            {
                                <div class="alert alert-warning mt-3 mb-0">
                                    Check-in blocked: membership is not active. Renew/activate membership first.
                                </div>
                            }
                            else if (member.HasPendingPayMongoPayment)
                            {
                                <div class="alert alert-warning mt-3 mb-0">
                                    Check-in blocked: pending online payment detected. Resolve payment first.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info mt-3 mb-0">
                                    Check-in is ready. Manual check-out is optional; system auto-closes after @Model.AutoCheckoutHours hours.
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light border mt-4 mb-0">
                            No member selected yet. Search by name/code/email or use the QR scanner.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Shift Snapshot</h5>
                    <span class="text-muted small">Live</span>
                </div>
                <div class="card-body">
                    <a class="d-flex justify-content-between mb-2 text-decoration-none text-reset" href="#today-frontdesk-activity">
                        <span class="ejc-muted">On Floor Now</span>
                        <strong>@Model.Snapshot.CheckedInNow</strong>
                    </a>
                    <a class="d-flex justify-content-between mb-2 text-decoration-none text-reset" href="#today-frontdesk-activity">
                        <span class="ejc-muted">Closed Today (Manual + Auto)</span>
                        <strong>@Model.Snapshot.CheckedOutToday</strong>
                    </a>
                    <a class="d-flex justify-content-between text-decoration-none text-reset" asp-page="/Staff/PlanStatus">
                        <span class="ejc-muted">Plan Expiring Today</span>
                        <strong>@Model.Snapshot.PlanExpiringToday</strong>
                    </a>
                    <div class="small text-muted mt-3">
                        Pending payment monitoring is available in <a class="text-decoration-none" asp-page="/Staff/PlanStatus">Plan Status</a>.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card" id="today-frontdesk-activity">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h5 class="mb-0">Today's Front Desk Activity</h5>
            <span class="text-muted small">Latest check-ins / check-outs</span>
        </div>
        <div class="card-body p-0">
            @if (Model.RecentActivities.Count == 0)
            {
                <div class="p-4">
                    <p class="ejc-muted mb-0">No attendance activity captured yet for today.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Time (local)</th>
                                <th>Member</th>
                                <th>Action</th>
                                <th>Staff</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <tr>
                                    <td>@activity.TimeLocal.ToString("yyyy-MM-dd HH:mm zzz")</td>
                                    <td>@activity.MemberDisplayName</td>
                                    <td>@activity.Action</td>
                                    <td>@activity.HandledBy</td>
                                    <td><span class="@activity.StatusBadgeClass">@activity.StatusLabel</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/html5-qrcode/html5-qrcode.min.js" asp-append-version="true"></script>
    <script>
        (() => {
            const form = document.querySelector("[data-ejc-checkin-search-form]");
            const searchInput = document.getElementById("SearchTerm");
            const readerElementId = "checkin-qr-reader";
            const startButton = document.getElementById("start-qr-scan");
            const stopButton = document.getElementById("stop-qr-scan");
            const statusText = document.getElementById("checkin-qr-status");

            if (!form || !searchInput || !startButton || !stopButton || !statusText) {
                return;
            }

            if (typeof Html5Qrcode === "undefined") {
                startButton.disabled = true;
                setStatus("QR scanner library did not load.", true);
                return;
            }

            const scannerConfig = { fps: 10, qrbox: { width: 220, height: 220 } };
            let scanner = null;
            let scanning = false;
            let starting = false;
            let scanLocked = false;

            function normalizePayload(rawValue) {
                const value = (rawValue || "").trim().replace(/^["']|["']$/g, "");
                if (!value) {
                    return "";
                }

                const prefix = "EJC-MEMBER:";
                if (value.toUpperCase().startsWith(prefix)) {
                    return value.substring(prefix.length).trim();
                }

                return value;
            }

            function setStatus(message, isError) {
                statusText.textContent = message;
                statusText.className = `small mt-2 ${isError ? "text-danger" : "text-muted"}`;
            }

            function refreshButtonState() {
                startButton.disabled = scanning || starting;
                stopButton.disabled = !scanning && !starting;
            }

            function toStatusMessage(error, fallbackMessage) {
                const rawMessage = (error && typeof error.message === "string")
                    ? error.message
                    : (typeof error === "string" ? error : "");

                const normalized = rawMessage.toLowerCase();
                if (normalized.includes("notallowederror") || normalized.includes("permission")) {
                    return "Camera access was blocked. Allow camera permission in your browser and retry.";
                }

                if (normalized.includes("notfounderror") || normalized.includes("no camera")) {
                    return "No camera was detected for this device.";
                }

                if (normalized.includes("notreadableerror") || normalized.includes("could not start video source")) {
                    return "Camera is busy or unavailable. Close other apps using the camera and retry.";
                }

                if (!window.isSecureContext &&
                    window.location.hostname !== "localhost" &&
                    window.location.hostname !== "127.0.0.1") {
                    return "Camera requires HTTPS (or localhost). Open this page over a secure URL.";
                }

                return fallbackMessage;
            }

            async function startWithConstraint(cameraConstraint) {
                const readerElement = document.getElementById(readerElementId);
                if (readerElement) {
                    readerElement.innerHTML = "";
                }

                const nextScanner = new Html5Qrcode(readerElementId, { verbose: false });
                await nextScanner.start(
                    cameraConstraint,
                    scannerConfig,
                    onScanSuccess,
                    () => { }
                );

                scanner = nextScanner;
                scanning = true;
            }

            async function startScanner() {
                if (scanning || starting) {
                    return;
                }

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    setStatus("This browser does not support camera access for QR scanning.", true);
                    return;
                }

                starting = true;
                refreshButtonState();
                setStatus("Starting camera scanner...", false);

                try {
                    try {
                        const cameras = await Html5Qrcode.getCameras();
                        if (!cameras || cameras.length === 0) {
                            setStatus("No camera detected for QR scanning.", true);
                            return;
                        }

                        const preferredCamera = cameras.find(camera =>
                            /back|rear|environment/i.test(camera.label ?? ""))
                            ?? cameras[0];

                        await startWithConstraint({ deviceId: { exact: preferredCamera.id } });
                        setStatus("Scanner is active. Point camera at member QR.", false);
                    } catch (cameraListError) {
                        try {
                            await startWithConstraint({ facingMode: "environment" });
                            setStatus("Scanner is active. Point camera at member QR.", false);
                        } catch (startError) {
                            setStatus(
                                toStatusMessage(
                                    startError,
                                    toStatusMessage(cameraListError, "Unable to start camera scanner on this device.")),
                                true);
                        }
                    }
                } finally {
                    starting = false;
                    refreshButtonState();
                }
            }

            async function stopScanner() {
                if (!scanning && !starting) {
                    return;
                }

                try {
                    if (scanner) {
                        await scanner.stop();
                    }
                } catch {
                    // Ignore stop errors to keep UI responsive.
                }

                try {
                    if (scanner) {
                        await scanner.clear();
                    }
                } catch {
                    // Ignore clear errors to keep UI responsive.
                }

                scanner = null;
                scanning = false;
                starting = false;
                refreshButtonState();
                setStatus("Scanner is off.", false);
            }

            async function onScanSuccess(decodedText) {
                if (scanLocked) {
                    return;
                }

                const memberToken = normalizePayload(decodedText);
                if (!memberToken) {
                    setStatus("QR read failed. Try again.", true);
                    return;
                }

                scanLocked = true;
                searchInput.value = memberToken;
                setStatus("QR detected. Searching member...", false);
                await stopScanner();
                form.submit();
            }

            startButton.addEventListener("click", () => {
                void startScanner();
            });

            stopButton.addEventListener("click", () => {
                void stopScanner();
            });

            window.addEventListener("beforeunload", () => {
                if (scanning) {
                    void stopScanner();
                }
            });
        })();
    </script>
}
