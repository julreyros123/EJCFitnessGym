@page
@model EJCFitnessGym.Pages.Finance.OperatingExpensesModel
@{
    ViewData["Title"] = "Operating Expenses";
    var currentSubPageLabel = Model.IsRecordsView ? "Expense Records" : "Add Operating Expense";
}

<div class="py-4">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Finance Module</span>
            <h1 class="h2 mb-1">Operating Expenses</h1>
            <p class="ejc-muted mb-0">Maintain clean operating costs for reliable profit and forecast reporting.</p>
        </div>
        <div class="ejc-actions d-flex gap-2">
            <a class="btn @(Model.IsAddView ? "btn-primary" : "btn-outline-primary")"
               asp-page="/Finance/OperatingExpenses"
               asp-route-view="add">Add Expense</a>
            <a class="btn @(Model.IsRecordsView ? "btn-primary" : "btn-outline-primary")"
               asp-page="/Finance/OperatingExpenses"
               asp-route-view="records">Expense Records</a>
            <form method="post" asp-page-handler="SeedTemplate" asp-route-view="add">
                <button type="submit" class="btn btn-outline-primary">Seed 6-Month Template</button>
            </form>
            <a class="btn btn-outline-primary" asp-page="/Finance/Dashboard">Back to Overview</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info py-2 px-3">@Model.StatusMessage</div>
    }

    @if (Model.Input.Id.HasValue)
    {
        <div class="alert alert-warning py-2 px-3 d-flex justify-content-between align-items-center">
            <span>You are editing expense record #@Model.Input.Id.</span>
            <a class="btn btn-sm btn-outline-dark" asp-page="/Finance/OperatingExpenses" asp-route-view="add">Cancel Edit</a>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card h-100"><div class="card-body"><div class="small text-muted">Expense (Last 30 Days)</div><div class="h4 mb-0" title="@($"PHP {Model.TotalExpenseLast30Days:N2}")">@Model.TotalExpenseLast30Days.ToCompactCurrency()</div></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100"><div class="card-body"><div class="small text-muted">Expense (Current Month)</div><div class="h4 mb-0" title="@($"PHP {Model.TotalExpenseCurrentMonth:N2}")">@Model.TotalExpenseCurrentMonth.ToCompactCurrency()</div></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100"><div class="card-body"><div class="small text-muted">Recurring (Current Month)</div><div class="h4 mb-0" title="@($"PHP {Model.RecurringExpenseCurrentMonth:N2}")">@Model.RecurringExpenseCurrentMonth.ToCompactCurrency()</div></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card h-100"><div class="card-body"><div class="small text-muted">One-Time (Current Month)</div><div class="h4 mb-0" title="@($"PHP {Model.OneTimeExpenseCurrentMonth:N2}")">@Model.OneTimeExpenseCurrentMonth.ToCompactCurrency()</div></div></div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-4">
            <div class="card h-100"><div class="card-body"><div class="small text-muted">Active Expense Records</div><div class="h4 mb-0">@Model.Expenses.Count(x => x.IsActive)</div></div></div>
        </div>
        <div class="col-md-6 col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Top Category (Current Month)</div>
                    <div class="h5 mb-1">@Model.TopCategoryCurrentMonth</div>
                    <div class="small text-muted" title="@($"PHP {Model.TopCategoryCurrentMonthAmount:N2}")">@Model.TopCategoryCurrentMonthAmount.ToCompactCurrency()</div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">Current Sub-Page</div>
                    <div class="h5 mb-2">@currentSubPageLabel</div>
                    <div class="small text-muted mb-2">Use sidebar Operating Expenses dropdown or the quick buttons above to switch views.</div>
                    <hr />
                    <div class="small text-muted mb-1">Recommended Controls</div>
                    <ul class="small mb-0 ps-3">
                        <li>Use recurring flag for fixed monthly costs.</li>
                        <li>Keep notes short and audit-friendly (invoice ref, vendor, reason).</li>
                        <li>Review inactive records monthly and archive stale entries.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @if (Model.IsAddView)
    {
        <div class="row g-4 mb-4">
            <div class="col-12 col-xxl-8">
                <div class="card h-100">
                    <div class="card-header"><h5 class="mb-0">Add Operating Expense</h5></div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="Add" asp-route-view="add" class="row g-3">
                            <input asp-for="Input.Id" type="hidden" />
                            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                            <div class="col-12">
                                <label asp-for="Input.Name" class="form-label"></label>
                                <input asp-for="Input.Name" class="form-control" placeholder="Example: Branch Rent - February" />
                                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Category" class="form-label"></label>
                                <select asp-for="Input.Category" class="form-select">
                                    <option value="">Select category</option>
                                    @foreach (var category in Model.CategoryOptions)
                                    {
                                        <option value="@category">@category</option>
                                    }
                                </select>
                                <span asp-validation-for="Input.Category" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Amount" class="form-label"></label>
                                <input asp-for="Input.Amount" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                <span asp-validation-for="Input.Amount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.ExpenseDateUtc" class="form-label"></label>
                                <input asp-for="Input.ExpenseDateUtc" class="form-control" type="date" />
                                <span asp-validation-for="Input.ExpenseDateUtc" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <details class="ejc-finance-sub-dropdown" @(Model.Input.Id.HasValue ? "open" : null)>
                                    <summary>More Options</summary>
                                    <div class="row g-3 mt-1">
                                        <div class="col-md-6">
                                            <label asp-for="Input.ReferenceCode" class="form-label"></label>
                                            <input asp-for="Input.ReferenceCode" class="form-control" placeholder="Invoice no. / OR no. / PO ref" />
                                            <span asp-validation-for="Input.ReferenceCode" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="Input.Notes" class="form-label"></label>
                                            <textarea asp-for="Input.Notes" class="form-control" rows="1" placeholder="Optional reference: vendor, invoice no., context"></textarea>
                                            <span asp-validation-for="Input.Notes" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 d-flex flex-wrap gap-3">
                                            <div class="form-check">
                                                <input asp-for="Input.IsRecurring" class="form-check-input" />
                                                <label asp-for="Input.IsRecurring" class="form-check-label"></label>
                                            </div>
                                            <div class="form-check">
                                                <input asp-for="Input.IsActive" class="form-check-input" />
                                                <label asp-for="Input.IsActive" class="form-check-label"></label>
                                            </div>
                                        </div>
                                    </div>
                                </details>
                            </div>

                            <div class="col-12 small text-muted">
                                One-time expenses require a reference code for audit traceability.
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">@Model.SubmitButtonLabel</button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.Input.Category) &&
                                 !Model.CategoryOptions.Contains(Model.Input.Category, StringComparer.OrdinalIgnoreCase))
                            {
                                <div class="col-12">
                                    <div class="small text-warning">
                                        Current category "@Model.Input.Category" is not in defaults. You can keep it or choose a standard category above.
                                    </div>
                                </div>
                            }
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-12 col-xxl-4">
                <div class="card h-100">
                    <div class="card-header"><h5 class="mb-0">Entry Tips</h5></div>
                    <div class="card-body">
                        <ul class="small mb-3 ps-3">
                            <li>Use consistent naming so reports are easier to filter.</li>
                            <li>Keep category aligned with budget buckets for cleaner variance reports.</li>
                            <li>For one-time costs, include OR or invoice number in reference code.</li>
                        </ul>
                        <a class="btn btn-outline-primary btn-sm"
                           asp-page="/Finance/OperatingExpenses"
                           asp-route-view="records">Review Existing Records</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.IsRecordsView)
    {
        <div class="card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Category Budget vs Actual (Current Month)</h5>
                <div class="small text-muted d-flex gap-3 flex-wrap">
                    <span title="@($"PHP {Model.TotalBudgetCurrentMonth:N2}")">Budget: <strong>@Model.TotalBudgetCurrentMonth.ToCompactCurrency()</strong></span>
                    <span title="@($"PHP {Model.TotalActualCurrentMonth:N2}")">Actual: <strong>@Model.TotalActualCurrentMonth.ToCompactCurrency()</strong></span>
                    <span>
                        Variance:
                        <strong class="@(Model.TotalVarianceCurrentMonth > 0m ? "text-danger" : Model.TotalVarianceCurrentMonth < 0m ? "text-success" : string.Empty)"
                                title="@($"PHP {Model.TotalVarianceCurrentMonth:N2}")">
                            @Model.TotalVarianceCurrentMonth.ToCompactCurrency()
                        </strong>
                    </span>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0 ejc-finance-table"
                           data-ejc-page-size="8"
                           data-ejc-search-placeholder="Search category">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Budget</th>
                                <th class="text-end">Actual</th>
                                <th class="text-end">Variance</th>
                                <th class="text-end">Variance %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.CategoryBudgetRows)
                            {
                                <tr>
                                    <td>@row.Category</td>
                                    <td class="text-end text-nowrap">PHP @row.BudgetAmount.ToString("N2")</td>
                                    <td class="text-end text-nowrap">PHP @row.ActualAmount.ToString("N2")</td>
                                    <td class="text-end text-nowrap @(row.VarianceAmount > 0m ? "text-danger" : row.VarianceAmount < 0m ? "text-success" : string.Empty)">
                                        PHP @row.VarianceAmount.ToString("N2")
                                    </td>
                                    <td class="text-end text-nowrap @(row.VariancePercent > 0m ? "text-danger" : row.VariancePercent < 0m ? "text-success" : string.Empty)">
                                        @(row.VariancePercent.HasValue ? $"{row.VariancePercent.Value:+0.##;-0.##;0}%" : "-")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Expense Records</h5>
                <span class="text-muted small">@Model.Expenses.Count item(s)</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover align-middle mb-0"
                           data-ejc-page-size="10"
                           data-ejc-search-placeholder="Search expense, category, or notes">
                        <thead>
                            <tr>
                                <th>Date (UTC)</th>
                                <th>Expense</th>
                                <th>Category</th>
                                <th>Type</th>
                                <th class="text-end">Amount</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Expenses.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-3">No expense records found for this branch.</td>
                                </tr>
                            }
                            @foreach (var item in Model.Expenses)
                            {
                                <tr>
                                    <td class="text-nowrap">@item.ExpenseDateUtc.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <div class="fw-semibold">@item.Name</div>
                                        <div class="small text-muted">@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</div>
                                    </td>
                                    <td><span class="badge text-bg-dark border border-secondary">@item.Category</span></td>
                                    <td>
                                        <span class="badge @(item.IsRecurring ? "bg-info text-dark" : "bg-secondary")">
                                            @(item.IsRecurring ? "Recurring" : "One-Time")
                                        </span>
                                    </td>
                                    <td class="text-end text-nowrap">PHP @item.Amount.ToString("N2")</td>
                                    <td>
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Active" : "Inactive")</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-1">
                                            <a class="btn btn-sm btn-outline-info"
                                               asp-page="/Finance/OperatingExpenses"
                                               asp-route-view="add"
                                               asp-route-editId="@item.Id">Edit</a>
                                            <form method="post"
                                                  asp-page-handler="ToggleActive"
                                                  asp-route-id="@item.Id"
                                                  asp-route-view="records">
                                                <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                                    @(item.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
