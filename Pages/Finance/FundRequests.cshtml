@page
@model EJCFitnessGym.Pages.Finance.FundRequestsModel
@{
    ViewData["Title"] = "Fund Queue";
}

<div class="py-4">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Finance Queue</span>
            <h1 class="h2 mb-1">Fund Queue</h1>
            <p class="ejc-muted mb-0">Finance reviews incoming requests and releases funds once each request is cleared.</p>
        </div>
        <div class="ejc-actions">
            <a class="btn btn-outline-primary" asp-page="/Finance/Dashboard">Back to Overview</a>
        </div>
    </div>

    <div class="alert alert-info py-2 px-3 mb-4">
        <span class="small">
            Workflow: <strong>Request received</strong> -> <strong>Clearance check</strong> -> <strong>Finance release action</strong> -> <strong>Queue closes as completed</strong>.
            This page only shows fund-request queue items relevant to finance release.
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <article class="ejc-admin-metric h-100">
                <div class="ejc-admin-metric-link">
                    <span class="ejc-admin-metric-label">Waiting Clearance</span>
                    <strong>@Model.AwaitingClearanceCount</strong>
                </div>
            </article>
        </div>
        <div class="col-sm-6 col-xl-3">
            <article class="ejc-admin-metric h-100">
                <div class="ejc-admin-metric-link">
                    <span class="ejc-admin-metric-label">Ready To Release</span>
                    <strong>@Model.ReadyToReleaseCount</strong>
                </div>
            </article>
        </div>
        <div class="col-sm-6 col-xl-3">
            <article class="ejc-admin-metric h-100">
                <div class="ejc-admin-metric-link">
                    <span class="ejc-admin-metric-label">Released</span>
                    <strong>@Model.ReleasedCount</strong>
                </div>
            </article>
        </div>
        <div class="col-sm-6 col-xl-3">
            <article class="ejc-admin-metric h-100">
                <div class="ejc-admin-metric-link">
                    <span class="ejc-admin-metric-label">Returned / Cancelled</span>
                    <strong>@Model.ReturnedCount</strong>
                </div>
            </article>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h5 class="mb-0">Fund Request Queue (Finance Action Only)</h5>
            <span class="text-muted small">@Model.QueueRows.Count item(s) • Branch scoped</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0 ejc-finance-table ejc-table-sticky"
                       data-ejc-page-size="7"
                       data-ejc-search-placeholder="Search request, branch, approval, action, or status">
                    <thead>
                        <tr>
                            <th>Request #</th>
                            <th>Branch</th>
                            <th>Requested On</th>
                            <th class="text-end">Amount</th>
                            <th>Clearance</th>
                            <th>Finance Action</th>
                            <th>Queue Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.QueueRows.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-3">No branch-scoped fund requests yet.</td>
                            </tr>
                        }
                        @foreach (var row in Model.QueueRows)
                        {
                            <tr>
                                <td>@row.RequestNumber</td>
                                <td>@row.Branch</td>
                                <td class="text-nowrap">@row.RequestedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="text-end text-nowrap">PHP @row.Amount.ToString("N2")</td>
                                <td><span class="@FundRequestsModel.ClearanceBadgeClass(row.ClearanceState)">@row.ClearanceState</span></td>
                                <td><span class="@FundRequestsModel.FinanceActionBadgeClass(row.FinanceAction)">@row.FinanceAction</span></td>
                                <td><span class="@FundRequestsModel.QueueStatusBadgeClass(row.QueueStatus)">@row.QueueStatus</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
