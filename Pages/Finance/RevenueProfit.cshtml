@page
@model EJCFitnessGym.Pages.Finance.RevenueProfitModel
@using System.Globalization
@{
    ViewData["Title"] = "Revenue & Profit";
}

<div class="py-4">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Finance Module</span>
            <h1 class="h2 mb-1">Revenue &amp; Profit</h1>
            <p class="ejc-muted mb-0">Track monthly revenue performance, gross profit, net profit, and margin trend.</p>
        </div>
        <div class="ejc-actions">
            <a class="btn btn-outline-primary" asp-page="/Finance/Dashboard">Back to Overview</a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Revenue and Profit Summary</h5>
                    <span class="text-muted small">
                        @Model.CurrentCycle.MonthStartUtc.ToString("MMM yyyy") cycle
                    </span>
                </div>
                <div class="card-body">
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Total Revenue</span>
                        <strong title="@($"PHP {Model.CurrentCycle.Revenue:N2}")">@Model.CurrentCycle.Revenue.ToCompactCurrency()</strong>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Cost of Services</span>
                        <strong title="@($"PHP {Model.CurrentCycle.CostOfServices:N2}")">@Model.CurrentCycle.CostOfServices.ToCompactCurrency()</strong>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Gross Profit</span>
                        <strong title="@($"PHP {Model.CurrentCycle.GrossProfit:N2}")">@Model.CurrentCycle.GrossProfit.ToCompactCurrency()</strong>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Operating Expenses</span>
                        <strong title="@($"PHP {Model.CurrentCycle.OperatingExpenses:N2}")">@Model.CurrentCycle.OperatingExpenses.ToCompactCurrency()</strong>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Depreciation Cost</span>
                        <strong title="@($"PHP {Model.CurrentCycle.DepreciationCost:N2}")">@Model.CurrentCycle.DepreciationCost.ToCompactCurrency()</strong>
                    </div>
                    <div class="ejc-finance-stat mb-3">
                        <span class="ejc-muted">Net Profit</span>
                        <strong class="@(Model.CurrentCycle.NetProfit >= 0m ? "text-success" : "text-danger")"
                                title="@($"PHP {Model.CurrentCycle.NetProfit:N2}")">
                            @Model.CurrentCycle.NetProfit.ToCompactCurrency()
                        </strong>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="ejc-muted">Gross Margin</span>
                            <span>@Model.GrossMarginPercent.ToString("0.0")%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-info"
                                 style="width: @Model.GrossMarginWidthPercent.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="ejc-muted">Net Margin</span>
                            <span>@Model.NetMarginPercent.ToString("0.0")%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-success"
                                 style="width: @Model.NetMarginWidthPercent.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Revenue, Gross Profit, and Net Profit Analytics</h5>
                    <span class="text-muted small">Last 6 months + next month projection</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0 ejc-finance-table ejc-table-sticky"
                               data-ejc-page-size="7"
                               data-ejc-search-placeholder="Search period, trend, or amount">
                            <thead>
                                <tr>
                                    <th>Period</th>
                                    <th class="text-end">Revenue</th>
                                    <th class="text-end">Gross Profit</th>
                                    <th class="text-end">Net Profit</th>
                                    <th class="text-end">Net Margin</th>
                                    <th>Trend</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Rows.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-3">No revenue data available for this branch yet.</td>
                                    </tr>
                                }
                                @foreach (var row in Model.Rows)
                                {
                                    var snapshot = row.Snapshot;
                                    var netMargin = snapshot.Revenue > 0m
                                        ? (snapshot.NetProfit / snapshot.Revenue) * 100m
                                        : 0m;
                                    <tr>
                                        <td>
                                            @snapshot.MonthStartUtc.ToString("MMM yyyy")
                                            @if (snapshot.IsProjected)
                                            {
                                                <span class="small text-muted">(Projected)</span>
                                            }
                                        </td>
                                        <td class="text-end text-nowrap">PHP @snapshot.Revenue.ToString("N2")</td>
                                        <td class="text-end text-nowrap">PHP @snapshot.GrossProfit.ToString("N2")</td>
                                        <td class="text-end text-nowrap">PHP @snapshot.NetProfit.ToString("N2")</td>
                                        <td class="text-end">@netMargin.ToString("0.0")%</td>
                                        <td><span class="@row.TrendBadgeClass">@row.TrendLabel</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
