@page
@model EJCFitnessGym.Pages.Finance.DashboardModel
@{
    ViewData["Title"] = "Finance Dashboard";
}

<div class="py-4" data-finance-dashboard>
    <!-- No Data Alert -->
    <div class="alert alert-info alert-dismissible fade show d-none" role="alert" data-fin-no-data-alert>
        <div class="d-flex align-items-start gap-3">
            <i class="bi bi-info-circle-fill fs-4"></i>
            <div class="flex-grow-1">
                <h6 class="alert-heading mb-2">No Financial Data Found</h6>
                <p class="mb-2 small">The selected date range has no recorded payments or expenses. This could mean:</p>
                <ul class="mb-2 small">
                    <li>No member payments were processed during this period</li>
                    <li>No operating expenses were recorded</li>
                    <li>The date range is in the future or before business operations began</li>
                </ul>
                <p class="mb-0 small"><strong>Tip:</strong> Try selecting a different date range using the filter button, or use the "Last 30D" quick filter to see recent activity.</p>
                <div class="mt-3">
                    <button type="button" class="btn btn-sm btn-primary" data-fin-try-last-30d>
                        <i class="bi bi-calendar-range"></i> Try Last 30 Days
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-primary" data-fin-try-ytd>
                        <i class="bi bi-calendar-check"></i> Try Year to Date
                    </button>
                </div>
            </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <div class="ejc-page-header">
        <div class="ejc-finance-header-intro">
            <h1 class="h2 mb-1">Finance KPIs</h1>
            <p class="ejc-muted mb-0 ejc-finance-header-copy">Track the core revenue and profit metrics in one view.</p>
            <div class="ejc-finance-header-state" data-fin-header-state>
                <i class="bi bi-calendar-range"></i>
                <span>Last 30 days • Month to month</span>
            </div>
        </div>
        <div class="ejc-actions ejc-finance-actions">
            <button type="button"
                    class="btn btn-outline-primary ejc-filter-trigger ejc-finance-filter-trigger"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#financeFilterPanel"
                    aria-controls="financeFilterPanel"
                    title="Open finance filter">
                <i class="bi bi-funnel-fill"></i>
            </button>
            <div class="ejc-finance-link-actions">
                <a class="btn btn-primary" asp-page="/Finance/WeeklySalesAudit">Weekly Sales Audit</a>
                <a class="btn btn-outline-primary" asp-page="/Finance/FundRequests">Fund Queue</a>
                <a class="btn btn-outline-primary" asp-page="/Finance/OperatingExpenses" asp-route-view="records">Expense Records</a>
            </div>
        </div>
    </div>

    <div class="ejc-admin-metrics ejc-finance-kpi-grid">
        <article class="ejc-admin-metric ejc-finance-metric">
            <div class="ejc-admin-metric-link">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="ejc-admin-metric-label">Gross Revenue</span>
                    <span class="ejc-admin-metric-icon ejc-finance-icon-revenue"><i class="bi bi-currency-exchange"></i></span>
                </div>
                <strong class="ejc-finance-kpi-value" data-fin-kpi-value="grossRevenue">
                    <span class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </span>
                </strong>
                <span class="ejc-admin-metric-meta" data-fin-kpi-meta="grossRevenue">Loading data...</span>
            </div>
        </article>
        <article class="ejc-admin-metric ejc-finance-metric">
            <div class="ejc-admin-metric-link">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="ejc-admin-metric-label">Gross Profit</span>
                    <span class="ejc-admin-metric-icon ejc-finance-icon-profit"><i class="bi bi-graph-up"></i></span>
                </div>
                <strong class="ejc-finance-kpi-value" data-fin-kpi-value="grossProfit">
                    <span class="spinner-border spinner-border-sm text-success" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </span>
                </strong>
                <span class="ejc-admin-metric-meta" data-fin-kpi-meta="grossProfit">Loading data...</span>
            </div>
        </article>
        <article class="ejc-admin-metric ejc-finance-metric">
            <div class="ejc-admin-metric-link">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="ejc-admin-metric-label">Net Profit</span>
                    <span class="ejc-admin-metric-icon ejc-finance-icon-net"><i class="bi bi-wallet2"></i></span>
                </div>
                <strong class="ejc-finance-kpi-value" data-fin-kpi-value="netProfit">
                    <span class="spinner-border spinner-border-sm text-warning" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </span>
                </strong>
                <span class="ejc-admin-metric-meta" data-fin-kpi-meta="netProfit">Loading data...</span>
            </div>
        </article>
        <article class="ejc-admin-metric ejc-finance-metric">
            <div class="ejc-admin-metric-link">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="ejc-admin-metric-label">Projected Net Profit</span>
                    <span class="ejc-admin-metric-icon ejc-finance-icon-forecast"><i class="bi bi-calculator"></i></span>
                </div>
                <strong class="ejc-finance-kpi-value" data-fin-kpi-value="projectedNetProfit">
                    <span class="spinner-border spinner-border-sm text-info" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </span>
                </strong>
                <span class="ejc-admin-metric-meta" data-fin-kpi-meta="projectedNetProfit">Loading data...</span>
            </div>
        </article>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xxl-8">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Revenue vs Net Profit Trend</h5>
                    <span class="text-muted small" data-fin-trend-subtitle>Sep 2025 to Mar 2026</span>
                </div>
                <div class="card-body">
                    <div class="ejc-finance-chart-wrap">
                        <canvas id="financeTrendChart" aria-label="Revenue and net profit trend chart"></canvas>
                    </div>
                    <p class="ejc-muted mb-0 mt-3" data-fin-trend-summary>Performance line for the last 6 months plus next-month projection.</p>
                </div>
            </div>
        </div>

        <div class="col-xxl-4">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Profit Composition</h5>
                    <span class="text-muted small" data-fin-mix-subtitle>Current cycle</span>
                </div>
                <div class="card-body">
                    <div class="ejc-finance-chart-wrap ejc-finance-chart-wrap-sm mb-3">
                        <canvas id="financeMixChart" aria-label="Profit composition chart"></canvas>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Cost of Goods / Services</span>
                        <strong data-fin-mix-value="cogsShare">40.5%</strong>
                    </div>
                    <div class="ejc-finance-stat">
                        <span class="ejc-muted">Operating Expenses</span>
                        <strong data-fin-mix-value="opexShare">26.3%</strong>
                    </div>
                    <div class="ejc-finance-stat mb-0">
                        <span class="ejc-muted">Net Profit Margin</span>
                        <strong class="text-success" data-fin-mix-value="netMargin">33.2%</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-5">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Fund Request Pipeline</h5>
                    <span class="text-muted small" data-fin-pipeline-subtitle>Current workload</span>
                </div>
                <div class="card-body">
                    <div class="ejc-finance-chart-wrap ejc-finance-chart-wrap-sm ejc-finance-pipeline-chart">
                        <canvas id="financePipelineChart" aria-label="Fund request pipeline chart"></canvas>
                    </div>
                    <div class="ejc-finance-pipeline-breakdown mt-3">
                        <div class="ejc-finance-pipeline-chip is-review">
                            <span>For Review</span>
                            <div>
                                <strong data-fin-pipeline-value="forReview">0</strong>
                                <small data-fin-pipeline-share="forReview">0%</small>
                            </div>
                        </div>
                        <div class="ejc-finance-pipeline-chip is-pending">
                            <span>Pending</span>
                            <div>
                                <strong data-fin-pipeline-value="pending">0</strong>
                                <small data-fin-pipeline-share="pending">0%</small>
                            </div>
                        </div>
                        <div class="ejc-finance-pipeline-chip is-queued">
                            <span>Queued</span>
                            <div>
                                <strong data-fin-pipeline-value="queued">0</strong>
                                <small data-fin-pipeline-share="queued">0%</small>
                            </div>
                        </div>
                        <div class="ejc-finance-pipeline-chip is-approved">
                            <span>Approved</span>
                            <div>
                                <strong data-fin-pipeline-value="approved">0</strong>
                                <small data-fin-pipeline-share="approved">0%</small>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mt-3">
                        <p class="ejc-muted mb-0 small" data-fin-pipeline-note>Detailed request entries are available in the Fund Queue module.</p>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Finance/FundRequests">View Queue</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-7">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Focused Modules</h5>
                    <span class="text-muted small">Minimal finance navigation</span>
                </div>
                <div class="card-body">
                    <div class="ejc-finance-module-grid">
                        <a class="ejc-finance-module-link" asp-page="/Finance/WeeklySalesAudit">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Weekly Sales Audit</span>
                                <i class="bi bi-clipboard2-check"></i>
                            </span>
                            <span class="ejc-muted small">Audit sales submitted by staff before finance signoff.</span>
                        </a>
                        <a class="ejc-finance-module-link" asp-page="/Finance/FundRequests">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Fund Queue</span>
                                <i class="bi bi-cash-stack"></i>
                            </span>
                            <span class="ejc-muted small">Review and process requests forwarded by admin.</span>
                        </a>
                        <a class="ejc-finance-module-link" asp-page="/Finance/OperatingExpenses" asp-route-view="records">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Operating Expenses</span>
                                <i class="bi bi-wallet-fill"></i>
                            </span>
                            <span class="ejc-muted small">Maintain expense records and variance checks by category.</span>
                        </a>
                        <a class="ejc-finance-module-link" asp-page="/Finance/RevenueProfit">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Revenue &amp; Profit</span>
                                <i class="bi bi-graph-up-arrow"></i>
                            </span>
                            <span class="ejc-muted small">Track actual margins and financial outcomes.</span>
                        </a>
                        <a class="ejc-finance-module-link" asp-page="/Finance/NetForecast">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Net Forecast</span>
                                <i class="bi bi-calculator-fill"></i>
                            </span>
                            <span class="ejc-muted small">Predict next-cycle net results using current trend.</span>
                        </a>
                        <a class="ejc-finance-module-link" asp-page="/Finance/GeneralLedger">
                            <span class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">General Ledger</span>
                                <i class="bi bi-journal-bookmark-fill"></i>
                            </span>
                            <span class="ejc-muted small">Post journals and review branch trial balance.</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="offcanvas offcanvas-end ejc-filter-offcanvas" tabindex="-1" id="financeFilterPanel" aria-labelledby="financeFilterPanelLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="financeFilterPanelLabel">Finance Filter</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <p class="ejc-muted small mb-3">
                Filter by date range and trend mode. KPI cards and finance analytics update together.
            </p>

            <div class="mb-3">
                <label class="form-label small text-uppercase text-muted mb-2">Quick Range</label>
                <div class="d-grid gap-2">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Quick date range row 1">
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="today">Today</button>
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="7">Last 7D</button>
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="30">Last 30D</button>
                    </div>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Quick date range row 2">
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="ytd">YTD</button>
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="365">Last 1Y</button>
                        <button type="button" class="btn btn-outline-primary" data-fin-filter-quick="730">Last 2Y</button>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label for="financeFilterStartDate" class="form-label">From</label>
                <input id="financeFilterStartDate" type="date" class="form-control" data-fin-filter-start />
            </div>

            <div class="mb-3">
                <label for="financeFilterEndDate" class="form-label">To</label>
                <input id="financeFilterEndDate" type="date" class="form-control" data-fin-filter-end />
            </div>

            <div class="mb-4">
                <label for="financeFilterTrendMode" class="form-label">Trend Mode</label>
                <select id="financeFilterTrendMode" class="form-select" data-fin-trend-mode>
                    <option value="monthly">Month to month</option>
                    <option value="yearly">Year to year</option>
                </select>
            </div>

            <div class="d-grid gap-2">
                <button type="button" class="btn btn-primary" data-fin-filter-apply>Apply Filter</button>
                <button type="button" class="btn btn-outline-light" data-fin-filter-reset>Reset to Last 30 Days</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/finance-dashboard.js" asp-append-version="true"></script>
}
