@page "/Member/PaymentMethods"
@model EJCFitnessGym.Pages.Member.PaymentMethodsModel
@{
    ViewData["Title"] = "Payment Methods";
}

<section class="ejc-member-page">
    <div class="container">
        <partial name="/Pages/Shared/_MemberPortalNav.cshtml" />
        <partial name="/Pages/Shared/_MemberBillingShortcuts.cshtml" />

        <div class="row">
            <div class="col-lg-8">
                <h1 class="h3 mb-4">
                    <i class="bi bi-credit-card me-2"></i>Payment Methods
                </h1>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="card mb-4 border-primary">
                    <div class="card-header bg-primary text-white">
                        <i class="bi bi-lightning-charge me-2"></i>Renewal Settings
                    </div>
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h5 class="card-title">Subscription Renewal</h5>
                                <p class="card-text text-muted mb-0">
                                    @Model.RenewalAvailabilityMessage
                                </p>
                            </div>
                            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                @if (Model.AutomaticRenewalAvailable && Model.SavedMethods.Any(m => m.AutoBillingEnabled))
                                {
                                    <span class="badge bg-success fs-6">
                                        <i class="bi bi-check-circle me-1"></i>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge @(Model.AutomaticRenewalAvailable ? "bg-secondary" : "bg-warning text-dark") fs-6">
                                        <i class="bi @(Model.AutomaticRenewalAvailable ? "bi-x-circle" : "bi-exclamation-circle") me-1"></i>
                                        @(Model.AutomaticRenewalAvailable ? "Inactive" : "Manual Renewal")
                                    </span>
                                }
                            </div>
                        </div>

                        @if (Model.NextBillingDate is not null)
                        {
                            <hr />
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted">Next Billing Date</small>
                                    <div class="fw-bold">@Model.NextBillingDate</div>
                                </div>
                                @if (Model.NextBillingAmount.HasValue)
                                {
                                    <div class="text-end">
                                        <small class="text-muted">Amount</small>
                                        <div class="fw-bold text-primary fs-5">₱@Model.NextBillingAmount.Value.ToString("N2")</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Saved Payment Methods -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-wallet2 me-2"></i>Saved Payment Methods</span>
                        <a asp-page="/Public/Pricing" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Open Pricing
                        </a>
                    </div>
                    <div class="card-body">
                        @if (Model.SavedMethods.Count == 0)
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-credit-card-2-back fs-1 text-muted"></i>
                                <h5 class="mt-3">No Payment Methods Saved</h5>
                                <p class="text-muted">
                                    @Model.EmptyStateMessage
                                </p>
                                <a asp-page="/Public/Pricing" class="btn btn-primary">
                                    <i class="bi bi-credit-card me-1"></i>Pay Membership
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var method in Model.SavedMethods)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3">
                                                    @if (method.PaymentMethodType.Equals("card", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <i class="bi bi-credit-card fs-3 text-primary"></i>
                                                    }
                                                    else if (method.PaymentMethodType.Equals("gcash", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <i class="bi bi-phone fs-3 text-success"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-wallet fs-3 text-secondary"></i>
                                                    }
                                                </div>
                                                <div>
                                                    <div class="fw-bold">
                                                        @method.DisplayLabel
                                                        @if (method.IsDefault)
                                                        {
                                                            <span class="badge bg-primary ms-2">Default</span>
                                                        }
                                                    </div>
                                                    <small class="text-muted">
                                                        Added @method.CreatedUtc.ToLocalTime().ToString("MMMM d, yyyy")
                                                        @if (method.LastUsedUtc.HasValue)
                                                        {
                                                            <text> • Last used @method.LastUsedUtc.Value.ToLocalTime().ToString("MMMM d, yyyy")</text>
                                                        }
                                                    </small>
                                                    @if (method.FailedAttempts > 0)
                                                    {
                                                        <div>
                                                            <span class="badge bg-warning text-dark">
                                                                <i class="bi bi-exclamation-triangle me-1"></i>@method.FailedAttempts failed attempt(s)
                                                            </span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <!-- Auto-Pay Toggle -->
                                                <div class="form-check form-switch mb-2">
                                                    <form method="post" asp-page-handler="ToggleAutoBilling" class="d-inline">
                                                        <input type="hidden" name="methodId" value="@method.Id" />
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               role="switch"
                                                               id="autoPay-@method.Id"
                                                               @((Model.AutomaticRenewalAvailable && method.AutoBillingEnabled) ? "checked" : "")
                                                               @(!Model.AutomaticRenewalAvailable ? "disabled" : "")
                                                               onchange="this.form.submit()" />
                                                        <label class="form-check-label small" for="autoPay-@method.Id">
                                                            @(Model.AutomaticRenewalAvailable ? "Auto-Pay" : "Unavailable")
                                                        </label>
                                                    </form>
                                                </div>

                                                <div class="btn-group btn-group-sm">
                                                    @if (!method.IsDefault)
                                                    {
                                                        <form method="post" asp-page-handler="SetDefault" class="d-inline">
                                                            <input type="hidden" name="methodId" value="@method.Id" />
                                                            <button type="submit" class="btn btn-outline-primary btn-sm">
                                                                Set Default
                                                            </button>
                                                        </form>
                                                    }
                                                    <form method="post" asp-page-handler="Remove" class="d-inline"
                                                          onsubmit="return confirm('Remove this payment method?');">
                                                        <input type="hidden" name="methodId" value="@method.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar Info -->
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="bi bi-info-circle me-2"></i>Current Renewal Flow
                        </h6>
                        <ul class="small mb-0 ps-3">
                            <li class="mb-2">Renewals are currently completed manually from the pricing or billing pages</li>
                            <li class="mb-2">PayMongo checkout still records each payment securely</li>
                            <li class="mb-2">You will receive confirmation after every successful payment</li>
                            <li class="mb-2">Outstanding invoices remain visible in your member portal</li>
                            <li>Automatic renewal will require a future PayMongo Subscriptions integration</li>
                        </ul>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="bi bi-shield-check me-2"></i>Secure Payments
                        </h6>
                        <p class="small text-muted mb-0">
                            Your payment information is securely stored with PayMongo. 
                            We never store your full card details on our servers.
                        </p>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="bi bi-question-circle me-2"></i>Need Help?
                        </h6>
                        <p class="small text-muted mb-2">
                            Having issues with payments or manual renewal?
                        </p>
                        <a href="mailto:support@ejcfitness.com" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-envelope me-1"></i>Contact Support
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
