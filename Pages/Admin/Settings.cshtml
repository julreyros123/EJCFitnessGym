@page
@model EJCFitnessGym.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Admin Settings";
}

<div class="py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Admin Settings</h1>
            <p class="text-muted mb-0">Role and platform controls used by the operations team.</p>
        </div>
        <div class="text-end">
            <small class="text-muted d-block">Scope</small>
            <strong>@Model.ScopeLabel</strong>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Admin Users</div>
                    <div class="fs-4 fw-bold">@Model.AdminUserCount</div>
                    <div class="small text-muted">Admin + SuperAdmin</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Staff Users</div>
                    <div class="fs-4 fw-bold">@Model.StaffUserCount</div>
                    <div class="small text-muted">Front desk + operations</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Finance Users</div>
                    <div class="fs-4 fw-bold">@Model.FinanceUserCount</div>
                    <div class="small text-muted">Finance module access</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Member Users</div>
                    <div class="fs-4 fw-bold">@Model.MemberUserCount</div>
                    <div class="small text-muted">Member portal accounts</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h6 mb-0">Security Baseline</h2>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Require confirmed email</dt>
                        <dd class="col-sm-6">@((Model.RequireConfirmedEmail ? "Enabled" : "Disabled"))</dd>
                        <dt class="col-sm-6">Secure cookies</dt>
                        <dd class="col-sm-6">@((Model.UseSecureCookies ? "Enabled" : "Disabled"))</dd>
                        <dt class="col-sm-6">Branch scope</dt>
                        <dd class="col-sm-6">@Model.BranchSummary</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">
                    <h2 class="h6 mb-0">Quick Actions</h2>
                </div>
                <div class="card-body d-grid gap-2">
                    <a class="btn btn-outline-primary text-start" asp-controller="StaffAccounts" asp-action="Index">Manage Staff Accounts</a>
                    <a class="btn btn-outline-primary text-start" asp-controller="MemberAccounts" asp-action="Index">Manage Member Accounts</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Admin/Inventory">Review Inventory Rules</a>
                    <a class="btn btn-outline-primary text-start" asp-page="/Admin/Payments">Review Collections</a>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <a class="btn btn-outline-primary text-start" asp-controller="UserBranches" asp-action="Index">Branch Access Mapping</a>
                    }
                    <a class="btn btn-outline-primary text-start" asp-area="Identity" asp-page="/Account/Manage/Index">Account Security</a>
                </div>
            </div>
        </div>
    </div>
</div>
