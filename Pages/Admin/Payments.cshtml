@page
@model EJCFitnessGym.Pages.Admin.PaymentsModel
@using EJCFitnessGym.Models.Billing
@{
    ViewData["Title"] = "Payments";
    var transactions = Model.Transactions;
    var recentSuccess = Model.RecentSuccessfulPayment;

    string StatusBadgeClass(PaymentStatus status)
    {
        return status switch
        {
            PaymentStatus.Succeeded => "bg-success",
            PaymentStatus.Pending => "bg-warning text-dark",
            PaymentStatus.Failed => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

<section class="ejc-admin-page">
    <div class="ejc-admin-layout" data-admin-layout>
        <partial name="/Pages/Shared/_AdminSidebar.cshtml" />

        <div class="ejc-admin-content">
            <div class="ejc-page-header">
                <div>
                    <span class="ejc-eyebrow">Billing</span>
                    <h1 class="display-6 mb-0">Payments</h1>
                    <p class="ejc-muted mb-0">Track collections, verify invoice status, and resolve pending dues.</p>
                </div>
                <div class="ejc-actions">
                    <a class="btn btn-primary" asp-controller="Invoices" asp-action="Create">Create Invoice</a>
                </div>
            </div>

            @if (recentSuccess is not null)
            {
                var recentSuccessPaidLocal = recentSuccess.PaidAtUtc.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt");
                <article class="ejc-payment-success-banner mb-4" role="status" aria-live="polite">
                    <div class="ejc-payment-success-icon" aria-hidden="true">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                    <div class="ejc-payment-success-copy">
                        <p class="ejc-payment-success-label mb-1">Payment Successful</p>
                        <h2 class="ejc-payment-success-title h5 mb-1">Invoice @recentSuccess.InvoiceNumber was paid successfully.</h2>
                        <p class="mb-0">
                            @recentSuccess.MemberDisplayName paid PHP @recentSuccess.Amount.ToString("N2") via @recentSuccess.Method on @recentSuccessPaidLocal.
                        </p>
                    </div>
                    <a class="btn btn-sm btn-outline-light ejc-payment-success-action"
                       asp-controller="Invoices"
                       asp-action="Details"
                       asp-route-id="@recentSuccess.InvoiceId">
                        View invoice
                    </a>
                </article>
            }

            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Recent Transactions</h5>
                    <span class="text-muted small">@transactions.Count record(s)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Invoice</th>
                                    <th>Member</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transactions.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No payment records found.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var payment in transactions)
                                    {
                                        var isRecentSuccess = recentSuccess is not null && payment.PaymentId == recentSuccess.PaymentId;
                                        <tr class="@(isRecentSuccess ? "ejc-payment-row-success" : null)">
                                            <td class="text-nowrap">@payment.InvoiceNumber</td>
                                            <td>
                                                <div class="fw-semibold">@payment.MemberDisplayName</div>
                                                <div class="text-muted small">@payment.MemberEmail</div>
                                            </td>
                                            <td class="text-nowrap">PHP @payment.Amount.ToString("N2")</td>
                                            <td>
                                                <div class="text-nowrap">@payment.Method</div>
                                                @if (!string.IsNullOrWhiteSpace(payment.GatewayProvider))
                                                {
                                                    <div class="text-muted small">@payment.GatewayProvider</div>
                                                }
                                            </td>
                                            <td class="text-nowrap">@payment.PaidAtUtc.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</td>
                                            <td>
                                                <span class="badge @StatusBadgeClass(payment.Status)">@payment.Status</span>
                                                @if (isRecentSuccess)
                                                {
                                                    <div class="small mt-1">Latest success</div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
