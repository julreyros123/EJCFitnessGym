@page
@model EJCFitnessGym.Pages.Admin.InventoryModel
@{
    ViewData["Title"] = "Inventory";
}

            <div class="ejc-page-header">
                <div>
                    <span class="ejc-eyebrow">Stockroom</span>
                    <h1 class="display-6 mb-0">Inventory</h1>
                    <p class="ejc-muted mb-0">Admin owns product stock movement. Staff submits requests, admin confirms stock-in, and finance closes the cost and audit steps.</p>
                </div>
            </div>

            <partial name="_AlertMessage" model='(Model.FlashMessage, Model.FlashType)' />

            <div class="alert alert-info py-2 px-3 mb-4">
                <span class="small">
                    Role split:
                    <strong>Staff</strong> submits request ->
                    <strong>Admin</strong> approves, orders, and confirms stock-in ->
                    <strong>Finance</strong> records expense, payment, and audit.
                    <br />
                    Workflow stages:
                    <strong>Requested</strong> ->
                    <strong>Approved</strong> ->
                    <strong>Ordered</strong> ->
                    <strong>Received Draft</strong> ->
                    <strong>Received Confirmed</strong> ->
                    <strong>Invoiced</strong> ->
                    <strong>Paid</strong> ->
                    <strong>Audited</strong>
                </span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-12">
                    <div class="card h-100">
                        <div class="card-header d-flex align-items-center justify-content-between">
                            <h5 class="mb-0">Current Product Stock</h5>
                            <span class="text-muted small">Admin-controlled on-hand count</span>
                        </div>
                        <div class="card-body p-0 ejc-table-shell-host">
                            <div class="table-responsive ejc-table-shell">
                                <table class="table table-sm table-striped table-hover align-middle mb-0"
                                       data-ejc-page-size="6"
                                       data-ejc-search-placeholder="Search SKU, item, category, or status">
                                    <thead>
                                        <tr>
                                            <th>SKU</th>
                                            <th>Item</th>
                                            <th>Category</th>
                                            <th class="text-end">On Hand</th>
                                            <th class="text-end">Reorder</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var stock in Model.StockItems)
                                        {
                                            <tr>
                                                <td>@stock.Sku</td>
                                                <td>@stock.Item</td>
                                                <td>@stock.Category</td>
                                                <td class="text-end">@stock.OnHand</td>
                                                <td class="text-end">@stock.ReorderLevel</td>
                                                <td><span class="@InventoryModel.StockStatusBadge(stock.Status)">@stock.Status</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Supply Workflow Tracker</h5>
                    <span class="text-muted small">Who owns the next step</span>
                </div>
                <div class="card-body p-0 ejc-table-shell-host">
                    <div class="table-responsive ejc-table-shell">
                        <table class="table table-sm table-striped table-hover align-middle mb-0"
                               data-ejc-page-size="7"
                               data-ejc-search-placeholder="Search request, branch, item, stage, or role">
                            <thead>
                                <tr>
                                    <th>Request #</th>
                                    <th>Branch</th>
                                    <th>Item</th>
                                    <th>Qty</th>
                                    <th>Current Stage</th>
                                    <th>Owner</th>
                                    <th>Next Owner</th>
                                    <th class="text-nowrap">Last Updated</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var flow in Model.WorkflowEntries)
                                {
                                    <tr>
                                        <td>@flow.RequestNo</td>
                                        <td>@flow.Branch</td>
                                        <td>@flow.Item</td>
                                        <td class="text-nowrap">@flow.Quantity</td>
                                        <td><span class="@InventoryModel.WorkflowStageBadge(flow.CurrentStage)">@flow.CurrentStage</span></td>
                                        <td><span class="@InventoryModel.RoleBadge(flow.CurrentOwner)">@flow.CurrentOwner</span></td>
                                        <td><span class="@InventoryModel.RoleBadge(flow.NextOwner)">@flow.NextOwner</span></td>
                                        <td class="text-nowrap">@flow.LastUpdated</td>
                                        <td class="text-end">
                                            @if (flow.CurrentStage != "Audited" && flow.CurrentStage != "Cancelled")
                                            {
                                                <form method="post" class="d-inline-flex gap-1">
                                                    <input type="hidden" name="id" value="@flow.Id" />
                                                    @if (flow.CurrentStage == "Requested")
                                                    {
                                                        <button asp-page-handler="Approve" class="btn btn-sm btn-outline-success">Approve Request</button>
                                                        <input type="hidden" name="reason" value="Declined by Admin" />
                                                        <button asp-page-handler="Cancel" class="btn btn-sm btn-outline-danger">Reject Request</button>
                                                    }
                                                    else if (flow.CurrentStage == "Approved")
                                                    {
                                                        <button asp-page-handler="Order" class="btn btn-sm btn-outline-primary">Mark Purchase Ordered</button>
                                                    }
                                                    else if (flow.CurrentStage == "Ordered" || flow.CurrentStage == "ReceivedDraft")
                                                    {
                                                        <button asp-page-handler="ConfirmReceipt" class="btn btn-sm btn-outline-success">Confirm Receipt + Stock In</button>
                                                    }
                                                    else if (flow.CurrentStage == "ReceivedConfirmed")
                                                    {
                                                        <button asp-page-handler="CreateExpense" class="btn btn-sm btn-outline-warning">Create Finance Expense</button>
                                                    }
                                                    else if (flow.CurrentStage == "Invoiced")
                                                    {
                                                        <button asp-page-handler="MarkPaid" class="btn btn-sm btn-outline-success">Mark Supplier Paid</button>
                                                    }
                                                    else if (flow.CurrentStage == "Paid")
                                                    {
                                                        <button asp-page-handler="MarkAudited" class="btn btn-sm btn-outline-dark">Close Audit</button>
                                                    }
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
