@page
@model EJCFitnessGym.Pages.Public.PricingModel
@{
    ViewData["Title"] = "Pricing";
    var pricingReturnUrl = Url.Page("/Public/Pricing");
}

<section class="enterprise-section">
    <div class="enterprise-section-head enterprise-section-head-inline">
        <div>
            <span class="enterprise-eyebrow">Membership Options</span>
            <h2>Choose the right monthly tier for your gym routine.</h2>
            <p class="enterprise-plan-sub mb-0">All plans are billed monthly. Cancel anytime.</p>
        </div>
        @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
        {
            <a class="btn enterprise-btn-secondary" asp-controller="Dashboard" asp-action="Member">Open Member Portal</a>
        }
        else
        {
            <a class="btn enterprise-btn-secondary" asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="@pricingReturnUrl">Join Now</a>
        }
    </div>

    @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-warning mt-3">@statusMessage</div>
    }

    @if (Model.ActivePendingCheckout is not null)
    {
        var pendingStartedLocal = Model.ActivePendingCheckout.StartedAtUtc.ToLocalTime().ToString("MMMM d, yyyy h:mm tt zzz");
        var pendingDueLocal = Model.ActivePendingCheckout.DueDateUtc.ToLocalTime().ToString("MMMM d, yyyy h:mm tt zzz");
        <div class="alert alert-warning mt-3">
            <strong>Pending checkout detected:</strong>
            Invoice @Model.ActivePendingCheckout.InvoiceNumber (started @pendingStartedLocal, due @pendingDueLocal).
            If you selected the wrong payment method, cancel this pending checkout below and start again.
            <form method="post" asp-page-handler="CancelPendingCheckout" class="mt-2 d-inline-block">
                <input type="hidden" name="paymentId" value="@Model.ActivePendingCheckout.PaymentId" />
                @if (Model.SelectedPlanId.HasValue)
                {
                    <input type="hidden" name="planId" value="@Model.SelectedPlanId.Value" />
                }
                @if (Model.CheckoutInvoice is not null)
                {
                    <input type="hidden" name="invoiceId" value="@Model.CheckoutInvoice.InvoiceId" />
                }
                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel Pending Checkout</button>
            </form>
        </div>
    }

    @if (Model.NextBillingDueDateUtc.HasValue)
    {
        var nextBillingLocal = Model.NextBillingDueDateUtc.Value.ToLocalTime().ToString("MMMM d, yyyy h:mm tt zzz");
        var reminderLocal = Model.ReminderScheduledDateUtc?.ToLocalTime().ToString("MMMM d, yyyy h:mm tt zzz") ?? "-";
        <div class="alert alert-info mt-3">
            <strong>Next billing date:</strong> @nextBillingLocal
            <br />
            <strong>3-day reminder date:</strong> @reminderLocal
        </div>
    }

    @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
    {
        <partial name="/Pages/Shared/_MemberBillingShortcuts.cshtml" />

        <div class="card mt-3">
            <div class="card-body">
                <h3 class="h5 mb-1">Choose Your Home Branch</h3>
                <p class="text-muted mb-3">You can work out at any active branch. Your home branch is used for billing defaults, member support, and ERP reporting.</p>

                @if (Model.AvailableBranches.Count == 0)
                {
                    <div class="alert alert-warning mb-0">No active branch is available yet. Please contact the admin team.</div>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <label for="home-branch-select" class="form-label">Home branch</label>
                            <select id="home-branch-select" class="form-select">
                                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SelectedHomeBranchId) ? "selected" : null)">Select a branch</option>
                                @foreach (var branch in Model.AvailableBranches)
                                {
                                    <option value="@branch.BranchId"
                                            selected="@(string.Equals(branch.BranchId, Model.SelectedHomeBranchId, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                        @branch.DisplayName
                                    </option>
                                }
                            </select>
                            <div class="form-text">All plans keep cross-branch access. The selected home branch is your default location.</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (Model.CheckoutInvoice is not null)
        {
            var focusedDueDate = Model.CheckoutInvoice.DueDateUtc.ToLocalTime().ToString("MMMM d, yyyy h:mm tt zzz");
            <div class="card mt-3 border-warning">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div>
                            <span class="enterprise-eyebrow">Invoice Checkout</span>
                            <h3 class="h5 mb-1">Pay @Model.CheckoutInvoice.InvoiceNumber</h3>
                            <p class="text-muted mb-2">
                                @(Model.CheckoutInvoice.PlanName is not null
                                    ? $"This invoice is tied to your {Model.CheckoutInvoice.PlanName} plan."
                                    : "This invoice is ready for online payment.")
                            </p>
                            <div class="small text-muted">Due date: @focusedDueDate</div>
                            @if (!string.IsNullOrWhiteSpace(Model.CheckoutInvoice.Notes))
                            {
                                <div class="small text-muted mt-1">@Model.CheckoutInvoice.Notes</div>
                            }
                        </div>
                        <div class="text-md-end">
                            <div class="h4 mb-3">PHP @Model.CheckoutInvoice.Amount.ToString("N2")</div>
                            <form method="post" asp-page-handler="Subscribe" class="d-grid gap-2">
                                <input type="hidden" name="invoiceId" value="@Model.CheckoutInvoice.InvoiceId" />
                                @if (Model.CheckoutInvoice.PlanId.HasValue)
                                {
                                    <input type="hidden" name="planId" value="@Model.CheckoutInvoice.PlanId.Value" />
                                }
                                <input type="hidden"
                                       name="homeBranchId"
                                       value="@Model.SelectedHomeBranchId"
                                       class="js-home-branch-input" />
                                <button type="submit" class="btn enterprise-btn-primary">
                                    <i class="bi bi-credit-card me-1"></i>Pay This Invoice
                                </button>
                                <a asp-page="/Member/Payments" class="btn btn-outline-secondary">Back to Payments</a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (Model.PlanCards.Count == 0)
    {
        <article class="enterprise-value-card">
            <span class="enterprise-value-icon"><i class="bi bi-info-circle"></i></span>
            <h3>No active monthly plans yet</h3>
            <p>Please check back soon or contact the team for available memberships.</p>
        </article>
    }
    else
    {
        <div class="enterprise-plan-grid">
            @foreach (var card in Model.PlanCards)
            {
                var buttonClass = card.IsFeatured ? "btn enterprise-btn-primary w-100" : "btn btn-outline-primary w-100";
                var returnToPlanUrl = Url.Page("/Public/Pricing", values: new { planId = card.PlanId });
                <article class="enterprise-plan-card d-flex flex-column @((card.IsFeatured || Model.SelectedPlanId == card.PlanId) ? "is-featured" : null)">
                    @if (!string.IsNullOrWhiteSpace(card.Badge))
                    {
                        <span class="enterprise-plan-tag">@card.Badge</span>
                    }
                    @if (Model.SelectedPlanId == card.PlanId)
                    {
                        <span class="enterprise-plan-tag">Selected</span>
                    }
                    <h3>@card.Name</h3>
                    <p class="enterprise-plan-sub">@card.Subtitle</p>
                    <div class="enterprise-plan-price">PHP @card.Price.ToString("N0") <small>/ month</small></div>
                    <ul>
                        @foreach (var benefit in card.Benefits.Take(4))
                        {
                            <li><i class="bi bi-check2-circle"></i>@benefit</li>
                        }
                    </ul>
                    @if (card.Benefits.Count > 4)
                    {
                        <div class="mb-3">
                            <a asp-page="/Public/PlanDetails" asp-route-id="@card.PlanId" class="text-decoration-none fw-semibold" style="color: var(--ejc-primary); font-size: 0.85rem;">
                                <i class="bi bi-info-circle me-1"></i>View all @card.Benefits.Count perks
                            </a>
                        </div>
                    }
                    <div class="mt-auto pt-3">
                        @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
                        {
                            <form method="post" asp-page-handler="Subscribe">
                                <input type="hidden" name="planId" value="@card.PlanId" />
                                <input type="hidden"
                                       name="homeBranchId"
                                       value="@Model.SelectedHomeBranchId"
                                       class="js-home-branch-input" />
                                <button type="submit" class="@buttonClass">@(Model.SelectedPlanId == card.PlanId ? $"Continue with {card.Name}" : $"Choose {card.Name}")</button>
                            </form>
                        }
                        else
                        {
                            <div class="d-grid gap-2">
                                <a class="btn btn-outline-primary w-100" asp-area="Identity" asp-page="/Account/Register" asp-route-planId="@card.PlanId" asp-route-returnUrl="@returnToPlanUrl">Create account</a>
                                <a class="btn btn-outline-light w-100" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@returnToPlanUrl">Login to Subscribe</a>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    }

    <article class="enterprise-contact-card mt-4">
        <h2>Need help choosing a tier?</h2>
        <p>Talk to our team and we will recommend the best plan based on your schedule and training goals.</p>
        <div class="enterprise-contact-actions">
            <a class="btn enterprise-btn-primary" href="tel:+639000000000">Call Us</a>
            <a class="btn enterprise-btn-secondary" asp-page="/Public/Contact">Message Team</a>
        </div>
    </article>
</section>

@if (User?.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
{
    <script>
        (() => {
            const homeBranchSelect = document.getElementById("home-branch-select");
            const hiddenInputs = document.querySelectorAll(".js-home-branch-input");
            if (!homeBranchSelect || hiddenInputs.length === 0) {
                return;
            }

            const syncSelectedBranch = () => {
                const branchId = homeBranchSelect.value || "";
                hiddenInputs.forEach((input) => {
                    input.value = branchId;
                });
            };

            homeBranchSelect.addEventListener("change", syncSelectedBranch);
            syncSelectedBranch();
        })();
    </script>
}
