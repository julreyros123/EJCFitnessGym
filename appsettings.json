{
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=EJCFitnessGym;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
    },
    "App": {
        "PublicBaseUrl": ""
    },
    "ForwardedHeaders": {
        "Enabled": true,
        "ForwardLimit": 1,
        "RequireHeaderSymmetry": true,
        "KnownProxies": [],
        "KnownNetworks": [
            "0.0.0.0/0",
            "::/0"
        ]
    },
    "Security": {},
    "Identity": {
        "RequireConfirmedEmail": true
    },
    "Email": {
        "Smtp": {
            "Host": "",
            "Port": 587,
            "EnableSsl": true,
            "UserName": "",
            "Password": "",
            "FromEmail": "",
            "FromName": "Fitness Gym"
        }
    },
    "Authentication": {
        "Google": {
            "ClientId": "",
            "ClientSecret": ""
        }
    },
    "PayMongo": {
        "SecretKey": "",
        "PublicKey": "",
        "SuccessUrl": "",
        "CancelUrl": "",
        "WebhookSecret": "",
        "WebhookSignatureToleranceSeconds": 300
    },
    "Jwt": {
        "Issuer": "EJCFitnessGym",
        "Audience": "EJCFitnessGymClients",
        "SigningKey": "",
        "AccessTokenMinutes": 60,
        "RefreshTokenDays": 14,
        "MaxActiveRefreshTokensPerUser": 5,
        "RevokedTokenRetentionDays": 30
    },
    "FinanceAlerts": {
        "Enabled": true,
        "EmailEnabled": false,
        "EmailRecipients": [
            "finance-alerts@ejcfit.local"
        ],
        "CooldownMinutes": 120,
        "LookbackDays": 120,
        "ForecastDays": 30,
        "MinHighSeverityAnomalies": 1
    },
    "FinanceAlertEvaluator": {
        "Enabled": true,
        "RunOnStartup": true,
        "IntervalMinutes": 30
    },
    "MembershipLifecycleWorker": {
        "Enabled": true,
        "RunOnStartup": true,
        "IntervalMinutes": 60,
        "PublishRealtimeWhenChangesDetected": true
    },
    "StaffAttendance": {
        "AutoCheckoutEnabled": true,
        "AutoCheckoutHours": 3,
        "AutoCloseIntervalMinutes": 10,
        "LookbackDays": 7,
        "MaxEventsPerSweep": 5000,
        "RunOnStartup": true
    },
    "IntegrationOutbox": {
        "Enabled": true,
        "PollIntervalSeconds": 5,
        "BatchSize": 100,
        "MaxAttempts": 10,
        "BaseRetryDelaySeconds": 10
    },
    "AutoBilling": {
        "Enabled": true,
        "IntervalMinutes": 60,
        "RunOnStartup": false,
        "PreferredHourUtc": 8,
        "MaxInvoicesPerRun": 100
    },
    "OperationalHealth": {
        "PendingOutboxWarningThreshold": 150,
        "PendingOutboxCriticalThreshold": 500,
        "PendingOutboxOldestWarningMinutes": 10,
        "PendingOutboxOldestCriticalMinutes": 30,
        "FailedOutboxWarningThreshold": 5,
        "FailedOutboxCriticalThreshold": 20,
        "FailedWebhookWarningThreshold": 5,
        "FailedWebhookCriticalThreshold": 20
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}