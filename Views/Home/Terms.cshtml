@{
    ViewData["Title"] = "Terms and Conditions";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-file-earmark-text text-primary fs-3"></i>
                </div>
                <div>
                    <h1 class="display-5 mb-0">Terms and Conditions</h1>
                    <p class="text-muted mb-0">Last Updated: March 7, 2026</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                <div class="card-body p-4 p-md-5">
                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">1. Agreement to Terms</h2>
                        <p class="ejc-muted">By accessing or using the <strong>Fitness Gym</strong> website and services, you agree to be bound by these Terms and Conditions. If you disagree with any part of the terms, then you may not access the service.</p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">2. Membership Rules</h2>
                        <ul class="ejc-muted">
                            <li>Members must provide accurate and complete information during registration.</li>
                            <li>Gym access is granted based on your specific subscription plan.</li>
                            <li>We reserve the right to suspend or terminate accounts for violations of gym rules or non-payment.</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">3. Payments and Billing</h2>
                        <p class="ejc-muted">Subscriptions are billed in advance based on your selected cycle (Monthly/Weekly/Yearly). All payments are processed via PayMongo. Refunds are subject to our refund policy, details of which can be requested at the front desk.</p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">4. Intellectual Property</h2>
                        <p class="ejc-muted">The Service and its original content, features, and functionality are and will remain the exclusive property of Fitness Gym and its licensors.</p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">5. Limitation of Liability</h2>
                        <p class="ejc-muted">In no event shall Fitness Gym, nor its directors, employees, or partners, be liable for any indirect, incidental, special, consequential or punitive damages resulting from your use of the service or gym facilities.</p>
                    </section>

                    <section>
                        <h2 class="h4 border-bottom pb-2 mb-3">6. Changes to Terms</h2>
                        <p class="ejc-muted">We reserve the right, at our sole discretion, to modify or replace these Terms at any time. We will try to provide at least 30 days' notice prior to any new terms taking effect.</p>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>
