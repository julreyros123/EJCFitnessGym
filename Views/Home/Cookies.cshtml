@{
    ViewData["Title"] = "Cookie Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-cookie text-primary fs-3"></i>
                </div>
                <div>
                    <h1 class="display-5 mb-0">Cookie Policy</h1>
                    <p class="text-muted mb-0">Published: March 7, 2026</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
                <div class="card-body p-4 p-md-5">
                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">1. What Are Cookies</h2>
                        <p class="ejc-muted">Cookies are small text files that are stored on your computer or mobile device when you visit a website. They are widely used to make websites work, or work more efficiently, as well as to provide information to the owners of the site.</p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">2. How We Use Cookies</h2>
                        <p class="ejc-muted">We use cookies for several reasons:</p>
                        <ul class="ejc-muted">
                            <li><strong>Essential Cookies:</strong> These are necessary for the website to function (e.g., maintaining your login session).</li>
                            <li><strong>Performance Cookies:</strong> These collect information about how you use our website (e.g., which pages you visit most).</li>
                            <li><strong>Functional Cookies:</strong> These allow the website to remember choices you make (e.g., your branch preference).</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">3. Third-Party Cookies</h2>
                        <p class="ejc-muted">We use Google Authentication, which may set cookies on your device to facilitate secure login. These cookies are managed by Google and are subject to Google's own cookie policy.</p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 border-bottom pb-2 mb-3">4. Managing Cookies</h2>
                        <p class="ejc-muted">Most web browsers allow some control of most cookies through the browser settings. To find out more about cookies, including how to see what cookies have been set and how to manage and delete them, visit <a href="https://www.aboutcookies.org" target="_blank">aboutcookies.org</a>.</p>
                    </section>

                    <section>
                        <h2 class="h4 border-bottom pb-2 mb-3">5. Consenting to Cookies</h2>
                        <p class="ejc-muted">By using our website, you consent to our use of cookies as described in this policy. If you do not agree, you should adjust your browser settings accordingly or stop using the site.</p>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>
