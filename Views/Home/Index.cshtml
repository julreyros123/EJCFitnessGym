@model EJCFitnessGym.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="enterprise-landing" id="home">
    <div class="enterprise-hero-shell enterprise-reveal d-flex align-items-center">
        <div class="enterprise-hero-grid modern-app-hero position-relative z-index-2" style="margin-top: -5rem;">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-8 mb-4 text-center enterprise-hero-copy">
                    <div class="brand-logo-accent mb-4 d-flex justify-content-center">
                        <i class="bi bi-hexagon-fill"></i>
                    </div>
                    
                    <h1 class="enterprise-hero-title mb-4">
                        Train Your <span class="neon-text">Body</span>,<br />
                        Elevate Your <span class="neon-text">Spirit</span>
                    </h1>
                    
                    <p class="modern-hero-subtitle mx-auto mb-5" style="max-width: 650px;">
                        Push past your limits, build unstoppable strength, and achieve the results you've always wanted. Join our community and transform your life with world-class facilities and expert guidance!
                    </p>

                    <div class="enterprise-hero-actions justify-content-center mt-4 mb-4">
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-modern-neon rounded-pill px-5 py-3 fw-bold shadow-lg">Get Started</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



<section class="enterprise-section">
    <div class="enterprise-section-head">
        <span class="enterprise-eyebrow">Why Choose Us</span>
        <h2>Everything your gym needs to keep members on track.</h2>
        <p>From front desk to training floor, your team works faster and your members get a smoother experience.</p>
    </div>

    <div class="enterprise-value-grid">
        <article class="enterprise-value-card enterprise-reveal">
            <span class="enterprise-value-icon"><i class="bi bi-person-vcard"></i></span>
            <h3>Member Progress in One Place</h3>
            <p>View attendance, payments, plan details, and coaching notes from one clear profile.</p>
        </article>

        <article class="enterprise-value-card enterprise-reveal enterprise-reveal-delay-1">
            <span class="enterprise-value-icon"><i class="bi bi-graph-up-arrow"></i></span>
            <h3>Coach and Front-Desk Visibility</h3>
            <p>Track active members, renewals, and class usage so your team can act quickly every day.</p>
        </article>

        <article class="enterprise-value-card enterprise-reveal enterprise-reveal-delay-2">
            <span class="enterprise-value-icon"><i class="bi bi-calendar2-check"></i></span>
            <h3>Smoother Daily Operations</h3>
            <p>Handle check-ins, billing reminders, and renewals without jumping between separate tools.</p>
        </article>

        <article class="enterprise-value-card enterprise-reveal enterprise-reveal-delay-3 p-0 overflow-hidden d-flex flex-column">
            <img src="~/images/gym-workout.png" alt="Better Workout Experience" class="w-100" style="height: 200px; object-fit: cover; object-position: center;" />
            <div class="p-4 flex-grow-1">
                <span class="enterprise-value-icon mb-3"><i class="bi bi-activity"></i></span>
                <h3>Better Workout Experience</h3>
                <p class="mb-0">Our organized environment helps members train more consistently with less friction and distractions.</p>
            </div>
        </article>

        <article class="enterprise-value-card enterprise-reveal enterprise-reveal-delay-4 p-0 overflow-hidden d-flex flex-column">
            <img src="~/images/gym-facility.png" alt="Safe & Secure Facility" class="w-100" style="height: 200px; object-fit: cover; object-position: center;" />
            <div class="p-4 flex-grow-1">
                <span class="enterprise-value-icon mb-3"><i class="bi bi-shield-check"></i></span>
                <h3>Safe & Secure Facility</h3>
                <p class="mb-0">Train with peace of mind in our fully insured, clean, and top-rated gym environment.</p>
            </div>
        </article>
        
        <article class="enterprise-value-card enterprise-reveal enterprise-reveal-delay-5 p-0 overflow-hidden d-flex flex-column">
            <img src="~/images/gym-equipment.png" alt="Premium Equipment" class="w-100" style="height: 200px; object-fit: cover; object-position: center;" />
            <div class="p-4 flex-grow-1">
                <span class="enterprise-value-icon mb-3"><i class="bi bi-lightning-charge"></i></span>
                <h3>Premium Equipment</h3>
                <p class="mb-0">Access high-quality, state-of-the-art machines and free weights to elevate your fitness journey.</p>
            </div>
        </article>
    </div>
</section>

<section class="enterprise-section" id="memberships">
    <div class="enterprise-section-head enterprise-section-head-inline">
        <div>
            <span class="enterprise-eyebrow">Membership Options</span>
            <h2>Simple monthly tiers built for real gym goals.</h2>
            <p class="enterprise-plan-sub mb-0">All plans are billed monthly. Cancel anytime.</p>
        </div>
        <a class="btn btn-outline-primary" asp-page="/Public/Pricing">See Full Plans</a>
    </div>

    @if (Model.PlanCards.Count == 0)
    {
        <article class="enterprise-value-card">
            <span class="enterprise-value-icon"><i class="bi bi-info-circle"></i></span>
            <h3>No active monthly plans yet</h3>
            <p>Please check back soon or contact the team for available memberships.</p>
        </article>
    }
    else
    {
        <div class="enterprise-plan-grid">
            @foreach (var card in Model.PlanCards)
            {
                <article class="enterprise-plan-card d-flex flex-column @((card.IsFeatured) ? "is-featured" : null)">
                    @if (!string.IsNullOrWhiteSpace(card.Badge))
                    {
                        <span class="enterprise-plan-tag">@card.Badge</span>
                    }
                    <h3>@card.Name</h3>
                    <p class="enterprise-plan-sub">@card.Subtitle</p>
                    <div class="enterprise-plan-price">PHP @card.Price.ToString("N0") <small>/ month</small></div>
                    <ul>
                        @foreach (var benefit in card.Benefits.Take(4))
                        {
                            <li><i class="bi bi-check2-circle"></i>@benefit</li>
                        }
                    </ul>
                    @if (card.Benefits.Count > 4)
                    {
                        <div class="mb-3">
                            <a asp-page="/Public/PlanDetails" asp-route-id="@card.PlanId" class="text-decoration-none fw-semibold" style="color: var(--ejc-primary); font-size: 0.85rem;">
                                <i class="bi bi-info-circle me-1"></i>View all @card.Benefits.Count perks
                            </a>
                        </div>
                    }
                    <div class="mt-auto pt-3">
                        <a class="btn @(card.IsFeatured ? "enterprise-btn-primary" : "btn-outline-primary") w-100" asp-page="/Public/Pricing" asp-route-planId="@card.PlanId">Choose @card.Name</a>
                    </div>
                </article>
            }
        </div>
    }
</section>

<section class="enterprise-section enterprise-contact-shell" id="contact">
    <div class="enterprise-contact-grid">
        <article class="enterprise-contact-card enterprise-reveal">
            <span class="enterprise-eyebrow">Contact</span>
            <h2>Talk to our team.</h2>
            <p>We can walk you through membership fit, coaching support, and the best plan for your training schedule.</p>
            <div class="enterprise-contact-meta">
                <div>
                    <small>Phone</small>
                    <strong>09979357906</strong>
                </div>
                <div>
                    <small>Email</small>
                    <strong>support@ejcfitnessgym.com</strong>
                </div>
                <div>
                    <small>Schedule</small>
                    <strong>Open 24 Hours</strong>
                </div>
            </div>
            <div class="enterprise-contact-actions">
                <a class="btn enterprise-btn-primary" href="tel:09979357906">Call Now</a>
                <a class="btn enterprise-btn-secondary" asp-page="/Public/Contact">Message Team</a>
            </div>
        </article>

        <div class="enterprise-testimonial-stack">
            <article class="enterprise-testimonial-card enterprise-reveal enterprise-reveal-delay-1">
                <i class="bi bi-quote"></i>
                <p>"Progress tracking became clearer for both members and coaches. We now move faster at the front desk."</p>
                <strong>Daniel S.</strong>
                <span>Senior Coach</span>
            </article>
            <article class="enterprise-testimonial-card enterprise-reveal enterprise-reveal-delay-2">
                <i class="bi bi-quote"></i>
                <p>"The billing and renewal flow reduced missed payments and made our monthly reporting easier."</p>
                <strong>Mae R.</strong>
                <span>Operations Team</span>
            </article>
        </div>
    </div>
</section>

<div class="enterprise-mobile-cta d-md-none">
    <a asp-area="Identity" asp-page="/Account/Register" class="btn enterprise-btn-primary btn-sm">Join Now</a>
    <a asp-page="/Public/Pricing" class="btn enterprise-btn-secondary btn-sm">Plans</a>
</div>
<div class="enterprise-mobile-spacer d-md-none"></div>
