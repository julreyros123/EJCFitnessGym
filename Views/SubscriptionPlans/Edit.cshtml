@model EJCFitnessGym.Models.Billing.SubscriptionPlan
@{
    ViewData["Title"] = "Edit Plan";
}

<div class="container py-5">
    <div class="ejc-table-toolbar mb-3">
        <div>
            <h1 class="display-6 mb-0">Edit Plan</h1>
            <p class="ejc-muted mb-0">Update pricing and plan details.</p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Tier" class="form-label"></label>
                        <select asp-for="Tier" class="form-select" asp-items="Html.GetEnumSelectList<EJCFitnessGym.Models.Billing.PlanTier>()"></select>
                        <span asp-validation-for="Tier" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="BillingCycle" class="form-label"></label>
                        <select asp-for="BillingCycle" class="form-select" asp-items="Html.GetEnumSelectList<EJCFitnessGym.Models.Billing.BillingCycle>()"></select>
                    </div>
                    <div class="col-md-4 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="alert alert-secondary">
                    <div class="fw-semibold mb-2">Tier rules are applied automatically on save.</div>
                    <div class="small mb-2">All plans keep cross-branch access. Update the tier if you need to change what members can use inside the branch.</div>
                    <ul class="mb-0 small">
                        <li><strong>Basic</strong>: basic equipment only.</li>
                        <li><strong>Pro</strong>: Basic plus cardio, group exercise, and free towel.</li>
                        <li><strong>Elite</strong>: Pro plus personal trainer, fitness plan, and full facility access.</li>
                    </ul>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
