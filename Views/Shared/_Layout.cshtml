@{
    var principal = User;
    var isAuthenticated = principal?.Identity?.IsAuthenticated == true;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var shareBaseUrl = string.IsNullOrWhiteSpace(Context?.Request?.Host.Value)
        ? "#"
        : $"{Context?.Request?.Scheme}://{Context?.Request?.Host.Value}";
    var isAuthAccountPage =
        requestPath.StartsWith("/Identity/Account/Login", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/Register", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/ForgotPassword", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/ResetPassword", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/ExternalLogin", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/ResendEmailConfirmation", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/RegisterConfirmation", StringComparison.OrdinalIgnoreCase) ||
        requestPath.StartsWith("/Identity/Account/ConfirmEmail", StringComparison.OrdinalIgnoreCase);
    var isBackOffice =
        (principal?.IsInRole("Staff") ?? false) ||
        (principal?.IsInRole("Finance") ?? false) ||
        (principal?.IsInRole("Admin") ?? false) ||
        (principal?.IsInRole("SuperAdmin") ?? false);
    var isMemberPortalUser = isAuthenticated && !isBackOffice;
    var rawMobileAccountName = principal?.Identity?.Name;
    var mobileAccountName = "Account";
    var configuration = Context?.RequestServices.GetService(typeof(Microsoft.Extensions.Configuration.IConfiguration)) as Microsoft.Extensions.Configuration.IConfiguration;
    var googleClientId = configuration?["Authentication:Google:ClientId"]?.Trim();
    var googleIdentityEnabled = !string.IsNullOrWhiteSpace(googleClientId);
    if (isAuthenticated && !string.IsNullOrWhiteSpace(rawMobileAccountName))
    {
        var mobileNameParts = rawMobileAccountName.Split('@', 2, StringSplitOptions.RemoveEmptyEntries);
        if (mobileNameParts.Length > 0 && !string.IsNullOrWhiteSpace(mobileNameParts[0]))
        {
            mobileAccountName = mobileNameParts[0];
        }
    }
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="google-site-verification" content="google48d8b3c9a0cc4a5c" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Fitness Gym - Comprehensive gym management system" />

    <title>@ViewData["Title"] - Fitness Gym</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EJCFitnessGym.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var bodyClasses = new List<string>();
    if (isBackOffice)
    {
        bodyClasses.Add("ejc-admin-body");
    }

    if (isAuthAccountPage && !isBackOffice)
    {
        bodyClasses.Add("ejc-public-auth-page");
    }
}
<body class="@string.Join(" ", bodyClasses)"
      data-ejc-backoffice-theme="@(isBackOffice ? "true" : "false")"
      data-ejc-theme="@(isBackOffice ? "dark" : "")"
      data-ejc-authenticated="@(isAuthenticated ? "true" : "false")">
@if (isBackOffice)
{
    <script>
        (() => {
            try {
                const storedTheme = localStorage.getItem("ejc.backoffice.theme");
                const resolvedTheme = (storedTheme === "light" || storedTheme === "dark")
                    ? storedTheme
                    : "dark";
                document.body.setAttribute("data-ejc-theme", resolvedTheme);
                document.documentElement.setAttribute("data-bs-theme", resolvedTheme);
            } catch {
                document.documentElement.setAttribute("data-bs-theme", "dark");
            }
        })();
    </script>
}
@if (isBackOffice)
{
    <partial name="_AdminTopbar" />
}
else
{
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark ejc-navbar">
            <div class="container-fluid ejc-nav-shell">
                <button class="navbar-toggler ejc-nav-trigger" type="button" data-bs-toggle="offcanvas" data-bs-target="#ejcNavSidebar" aria-controls="ejcNavSidebar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <a class="navbar-brand ejc-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Fitness Gym home">
                    <img class="ejc-brand-logo" src="~/images/logo-nav-transparent.png" asp-append-version="true" alt="Fitness Gym logo" />
                    <span class="ejc-brand-text" style="font-size: 1.1rem;">Fitness Gym</span>
                </a>
                @if (isAuthenticated)
                {
                    <div class="ejc-mobile-account d-lg-none">
                        <a class="ejc-mobile-quick" asp-area="Identity" asp-page="/Account/Manage/Index" asp-fragment="notifications" aria-label="Open notifications">
                            <i class="bi bi-bell" aria-hidden="true"></i>
                        </a>
                        <a class="ejc-mobile-account-name" asp-area="" asp-controller="Dashboard" asp-action="Profile" aria-label="Open my profile">@mobileAccountName</a>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 d-lg-none ms-auto me-2">
                        <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none text-light" style="font-size: 0.85rem; font-weight: 600;">Sign Up</a>
                        <span class="text-secondary" style="font-size: 0.85rem;">|</span>
                        <a asp-area="Identity" asp-page="/Account/Login" class="text-decoration-none" style="color: var(--ejc-primary); font-size: 0.85rem; font-weight: 600;">Login</a>
                    </div>
                }
                <div class="offcanvas offcanvas-start ejc-nav-offcanvas" data-bs-theme="dark" tabindex="-1" id="ejcNavSidebar" aria-label="Site navigation">
                    <div class="offcanvas-header d-lg-none">
                        <div class="ejc-nav-offcanvas-brand">
                            <img class="ejc-brand-logo-offcanvas" src="~/images/logo-nav-transparent.png" asp-append-version="true" alt="Fitness Gym logo" />
                            <span class="ejc-brand-text" style="font-size: 1rem; margin-left: 0.5rem;">Fitness Gym</span>
                        </div>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body ejc-nav-body">
                    <ul class="navbar-nav mb-2 mb-lg-0 ejc-main-nav">
                        @if (isMemberPortalUser)
                        {
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-area="" asp-controller="Dashboard" asp-action="Member">
                                    <i class="bi bi-grid-1x2-fill ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">My Portal</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-area="" asp-controller="Dashboard" asp-action="Profile">
                                    <i class="bi bi-person-circle ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">My Profile</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-page="/Public/Pricing">
                                    <i class="bi bi-card-checklist ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">Memberships</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-page="/Public/Contact">
                                    <i class="bi bi-life-preserver ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">Support</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-page="/Public/About">
                                    <i class="bi bi-info-circle ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">About</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" href="/#home">
                                    <i class="bi bi-house-door ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">Home</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" href="/#memberships">
                                    <i class="bi bi-card-checklist ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">Memberships</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" href="/#contact">
                                    <i class="bi bi-chat-dots ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">Contact</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link ejc-main-link" asp-page="/Public/About">
                                    <i class="bi bi-info-circle ejc-nav-icon" aria-hidden="true"></i>
                                    <span class="ejc-nav-label">About</span>
                                </a>
                            </li>
                            @if (isAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link ejc-main-link" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-speedometer2 ejc-nav-icon" aria-hidden="true"></i>
                                        <span class="ejc-nav-label">Control Hub</span>
                                    </a>
                                </li>

                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link ejc-main-link" asp-controller="Dashboard" asp-action="SuperAdmin">
                                            <i class="bi bi-shield-lock ejc-nav-icon" aria-hidden="true"></i>
                                            <span class="ejc-nav-label">Platform</span>
                                        </a>
                                    </li>
                                }
                                else if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link ejc-main-link" asp-page="/Admin/Dashboard">
                                            <i class="bi bi-shield-lock ejc-nav-icon" aria-hidden="true"></i>
                                            <span class="ejc-nav-label">Ops</span>
                                        </a>
                                    </li>
                                }

                                @if (User.IsInRole("Finance"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link ejc-main-link" asp-page="/Finance/Dashboard">
                                            <i class="bi bi-cash-coin ejc-nav-icon" aria-hidden="true"></i>
                                            <span class="ejc-nav-label">Revenue</span>
                                        </a>
                                    </li>
                                }

                                @if (User.IsInRole("Staff") || User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link ejc-main-link" asp-page="/Staff/CheckIn">
                                            <i class="bi bi-people ejc-nav-icon" aria-hidden="true"></i>
                                            <span class="ejc-nav-label">Floor Team</span>
                                        </a>
                                    </li>
                                }
                            }
                        }
                    </ul>
                    <!-- Mobile Footer Links (Share, Legal, Logout) styled exactly like Main Links -->
                    <ul class="navbar-nav mb-2 mb-lg-0 ejc-main-nav d-lg-none mt-3">
                        <li class="nav-item">
                            <span class="ejc-nav-mobile-section-title d-block px-3 mb-2 mt-2">Legal & Help</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-check ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">Privacy Policy</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" asp-area="" asp-controller="Home" asp-action="Terms">
                                <i class="bi bi-file-earmark-text ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">Terms & Conditions</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" asp-area="" asp-controller="Home" asp-action="Cookies">
                                <i class="bi bi-cookie ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">Cookie Policy</span>
                            </a>
                        </li>

                        <li class="nav-item">
                            <span class="ejc-nav-mobile-section-title d-block px-3 mb-2 mt-3">Share</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" href="https://www.facebook.com/sharer/sharer.php?u=@shareBaseUrl" target="_blank">
                                <i class="bi bi-facebook ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">Facebook</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" href="https://twitter.com/intent/tweet?url=@shareBaseUrl" target="_blank">
                                <i class="bi bi-twitter-x ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">X / Twitter</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link ejc-main-link" href="https://www.instagram.com/" target="_blank">
                                <i class="bi bi-instagram ejc-nav-icon" aria-hidden="true"></i>
                                <span class="ejc-nav-label">Instagram</span>
                            </a>
                        </li>

                        @if (isAuthenticated)
                        {
                            <li class="nav-item mt-3">
                                <form method="post" class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                    <button type="submit" class="nav-link ejc-main-link text-danger w-100 text-start border-0 bg-transparent">
                                        <i class="bi bi-box-arrow-right ejc-nav-icon text-danger" aria-hidden="true"></i>
                                        <span class="ejc-nav-label">Logout</span>
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>

                    <div class="d-none d-lg-flex align-items-center gap-2 ejc-nav-auth-wrap">
                        <partial name="_LoginPartial" />
                    </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>
}

    <div class="container app-shell @(isMemberPortalUser ? "ejc-member-shell" : "") @(isAuthAccountPage ? "ejc-auth-shell" : "")">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

@if (!isBackOffice && !isMemberPortalUser)
{
    <footer class="footer ejc-footer">
        <div class="container">
            <div class="ejc-footer-main">
                <section class="ejc-footer-col ejc-footer-brand ejc-reveal ejc-reveal-delay-1" data-ejc-reveal>
                    <h2>Fitness Gym</h2>
                    <p>Your neighborhood gym for strength, cardio, and consistent progress.</p>
                    <div class="ejc-footer-social" aria-label="Social media links">
                        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                            <i class="bi bi-youtube"></i>
                        </a>
                    </div>
                </section>

                <nav class="ejc-footer-col ejc-reveal ejc-reveal-delay-2" aria-label="Gym quick links" data-ejc-reveal>
                    <h3>Quick Links</h3>
                    <div class="ejc-footer-links">
                        <a asp-area="" asp-controller="Home" asp-action="Index" asp-fragment="home">Home</a>
                        <a asp-area="" asp-controller="Home" asp-action="Index" asp-fragment="memberships">Membership Plans</a>
                        <a asp-page="/Public/About">About the Gym</a>
                        <a asp-page="/Public/Contact">Contact Us</a>
                    </div>
                </nav>

                <nav class="ejc-footer-col ejc-reveal ejc-reveal-delay-3" aria-label="Member support links" data-ejc-reveal>
                    <h3>Member Support</h3>
                    <div class="ejc-footer-links">
                        <a asp-area="Identity" asp-page="/Account/Register">Join Now</a>
                        <a asp-area="Identity" asp-page="/Account/Login">My Account</a>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                        <a asp-area="" asp-controller="Home" asp-action="Terms">Terms & Conditions</a>
                    </div>
                </nav>

                <aside class="ejc-footer-notes ejc-reveal ejc-reveal-delay-4" aria-label="Member notes" data-ejc-reveal>
                    <h3>Member Notes</h3>
                    <ul>
                        <li>Need plan guidance? Ask for a Basic recommendation at the front desk.</li>
                        <li>For billing or account questions, use the support link for faster help.</li>
                        <li>New members should create an account first to access portal features.</li>
                    </ul>
                </aside>
            </div>
            <div class="ejc-footer-bottom ejc-reveal ejc-reveal-delay-4" data-ejc-reveal>
                <span>&copy; 2026 Fitness Gym</span>
                <div class="ejc-footer-bottom-links">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    <a asp-area="" asp-controller="Home" asp-action="Terms">Terms</a>
                    <a asp-area="" asp-controller="Home" asp-action="Cookies">Cookies</a>
                </div>
            </div>
        </div>
    </footer>
}
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @if (isAuthenticated)
    {
        <script src="~/lib/signalr/signalr.min.js" asp-append-version="true"></script>
        <script src="~/js/realtime-events.js" asp-append-version="true"></script>
    }
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (isAuthAccountPage && !isBackOffice && googleIdentityEnabled)
    {
        <script src="https://accounts.google.com/gsi/client" async defer></script>
    }
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
