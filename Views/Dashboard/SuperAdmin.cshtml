@model EJCFitnessGym.Models.Admin.SuperAdminDashboardViewModel
@{
    ViewData["Title"] = "Super Admin";
    Layout = "/Views/Shared/_SuperAdminLayout.cshtml";

    string SeverityBadgeClass(string severity)
    {
        if (string.Equals(severity, "High", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-danger";
        }

        if (string.Equals(severity, "Medium", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-warning text-dark";
        }

        return "bg-secondary";
    }

    string StateBadgeClass(string state)
    {
        if (string.Equals(state, "New", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-danger";
        }

        if (string.Equals(state, "Acknowledged", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-warning text-dark";
        }

        if (string.Equals(state, "Resolved", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-success";
        }

        return "bg-secondary";
    }

    string QueueLagLabel(DateTime? oldestPendingUtc)
    {
        if (!oldestPendingUtc.HasValue)
        {
            return "No pending queue backlog";
        }

        var lag = Model.AsOfUtc - oldestPendingUtc.Value;
        if (lag.TotalMinutes < 1)
        {
            return "Queue lag under 1 minute";
        }

        if (lag.TotalHours < 1)
        {
            return $"Queue lag {Math.Round(lag.TotalMinutes)} minutes";
        }

        if (lag.TotalDays < 1)
        {
            return $"Queue lag {Math.Round(lag.TotalHours, 1)} hours";
        }

        return $"Queue lag {Math.Round(lag.TotalDays, 1)} days";
    }

    string RetentionStatusBadgeClass(string status)
    {
        if (string.Equals(status, "Open", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-warning text-dark";
        }

        if (string.Equals(status, "InProgress", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-primary";
        }

        if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-success";
        }

        return "bg-secondary";
    }

    string ChurnRiskBadgeClass(string level)
    {
        if (string.Equals(level, "High", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-danger";
        }

        if (string.Equals(level, "Medium", StringComparison.OrdinalIgnoreCase))
        {
            return "bg-warning text-dark";
        }

        return "bg-success";
    }

    string RoleIcon(string roleName)
    {
        if (roleName.Contains("SuperAdmin", StringComparison.OrdinalIgnoreCase)) return "bi-shield-fill-check";
        if (roleName.Contains("Admin", StringComparison.OrdinalIgnoreCase)) return "bi-person-fill-gear";
        if (roleName.Contains("Finance", StringComparison.OrdinalIgnoreCase)) return "bi-bank";
        if (roleName.Contains("Staff", StringComparison.OrdinalIgnoreCase)) return "bi-person-badge-fill";
        if (roleName.Contains("Member", StringComparison.OrdinalIgnoreCase)) return "bi-person-fill";
        return "bi-person";
    }

    string RoleBadgeColor(string roleName)
    {
        if (roleName.Contains("SuperAdmin", StringComparison.OrdinalIgnoreCase)) return "sa-role-superadmin";
        if (roleName.Contains("Admin", StringComparison.OrdinalIgnoreCase)) return "sa-role-admin";
        if (roleName.Contains("Finance", StringComparison.OrdinalIgnoreCase)) return "sa-role-finance";
        if (roleName.Contains("Staff", StringComparison.OrdinalIgnoreCase)) return "sa-role-staff";
        return "sa-role-member";
    }
}

<div class="sa-dashboard">
    @* ── Header ── *@
    <div class="sa-header">
        <div class="sa-header-left">
            <h1 class="sa-title">Control Center</h1>
            <span class="sa-timestamp">
                <i class="bi bi-clock"></i>
                @Model.AsOfUtc.ToLocalTime().ToString("MMM dd, yyyy — h:mm tt")
            </span>
        </div>
        <div class="sa-header-right">
            <span class="sa-governance-badge">
                <i class="bi bi-shield-check"></i> Platform Governance
            </span>
        </div>
    </div>

    @* ── Unassigned Warning ── *@
    @if (Model.UnassignedBackOfficeCount > 0)
    {
        <div class="sa-warning-banner">
            <div class="sa-warning-content">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>
                    <strong>@Model.UnassignedBackOfficeCount back-office account(s)</strong> are missing branch scope assignment.
                </div>
            </div>
            <a class="btn btn-sm btn-light sa-warning-btn" asp-controller="UserBranches" asp-action="Index">
                <i class="bi bi-arrow-right-circle"></i> Resolve Now
            </a>
        </div>
    }

    @* ── Quick Actions ── *@
    <div class="sa-quick-actions">
        <a class="sa-action-btn sa-action-primary" asp-controller="UserBranches" asp-action="Index">
            <i class="bi bi-diagram-3-fill"></i>
            <span>Branch Access</span>
        </a>
        <a class="sa-action-btn" asp-controller="MemberAccounts" asp-action="Index">
            <i class="bi bi-people-fill"></i>
            <span>Members</span>
        </a>
        <a class="sa-action-btn" asp-controller="Invoices" asp-action="Index">
            <i class="bi bi-receipt-cutoff"></i>
            <span>Invoices</span>
        </a>
        <a class="sa-action-btn" asp-controller="SubscriptionPlans" asp-action="Index">
            <i class="bi bi-journal-text"></i>
            <span>Plans</span>
        </a>
        <a class="sa-action-btn" asp-controller="BackOfficeAccounts" asp-action="Index">
            <i class="bi bi-shield-lock-fill"></i>
            <span>Accounts</span>
        </a>
    </div>

    @* ── KPI Cards ── *@
    <div class="sa-kpi-grid">
        <div class="sa-kpi sa-kpi-lime">
            <div class="sa-kpi-icon"><i class="bi bi-building"></i></div>
            <div class="sa-kpi-body">
                <span class="sa-kpi-value">@Model.ActiveBranchCount</span>
                <span class="sa-kpi-label">Active Branches</span>
            </div>
        </div>
        <div class="sa-kpi sa-kpi-blue">
            <div class="sa-kpi-icon"><i class="bi bi-person-lines-fill"></i></div>
            <div class="sa-kpi-body">
                <span class="sa-kpi-value">@Model.TotalUserCount</span>
                <span class="sa-kpi-label">Platform Users</span>
            </div>
        </div>
        <div class="sa-kpi sa-kpi-emerald">
            <div class="sa-kpi-icon"><i class="bi bi-person-check-fill"></i></div>
            <div class="sa-kpi-body">
                <span class="sa-kpi-value">@Model.ActiveMemberCount</span>
                <span class="sa-kpi-label">Active Members</span>
            </div>
        </div>
        <div class="sa-kpi sa-kpi-amber">
            <div class="sa-kpi-icon"><i class="bi bi-currency-exchange"></i></div>
            <div class="sa-kpi-body">
                <span class="sa-kpi-value">₱@Model.RevenueThisMonth.ToString("N0")</span>
                <span class="sa-kpi-label">@Model.RevenuePeriodLabel Revenue</span>
            </div>
        </div>
    </div>

    @* ── Secondary Metrics ── *@
    <div class="sa-metrics-row">
        <div class="sa-metric">
            <div class="sa-metric-top">
                <span class="sa-metric-icon sa-metric-icon-orange"><i class="bi bi-file-earmark-text"></i></span>
                <span class="sa-metric-val">@Model.OpenInvoiceCount</span>
            </div>
            <span class="sa-metric-label">Open Invoices</span>
            <span class="sa-metric-sub">₱@Model.OpenInvoiceAmount.ToString("N2") outstanding</span>
        </div>
        <div class="sa-metric">
            <div class="sa-metric-top">
                <span class="sa-metric-icon sa-metric-icon-red"><i class="bi bi-bell-fill"></i></span>
                <span class="sa-metric-val">@Model.NewAlertCount</span>
            </div>
            <span class="sa-metric-label">Finance Alerts</span>
            <span class="sa-metric-sub">@Model.AcknowledgedAlertCount acknowledged</span>
        </div>
        <div class="sa-metric">
            <div class="sa-metric-top">
                <span class="sa-metric-icon sa-metric-icon-purple"><i class="bi bi-exclamation-octagon-fill"></i></span>
                <span class="sa-metric-val">@Model.FailedOutboxCount</span>
            </div>
            <span class="sa-metric-label">Outbox Failures</span>
            <span class="sa-metric-sub">Needs manual retry</span>
        </div>
        <div class="sa-metric">
            <div class="sa-metric-top">
                <span class="sa-metric-icon sa-metric-icon-teal"><i class="bi bi-hourglass-split"></i></span>
                <span class="sa-metric-val">@Model.PendingOutboxCount</span>
            </div>
            <span class="sa-metric-label">Queue Backlog</span>
            <span class="sa-metric-sub">@QueueLagLabel(Model.OldestPendingOutboxUtc)</span>
        </div>
    </div>

    @* ── User Authorization Panel ── *@
    <div class="sa-section">
        <div class="sa-section-header">
            <div class="sa-section-title">
                <i class="bi bi-shield-lock"></i>
                <h2>User Authorization</h2>
            </div>
            <div class="sa-section-meta">
                @foreach (var role in Model.RoleCounts)
                {
                    <span class="sa-role-pill @RoleBadgeColor(role.RoleName)">
                        <i class="bi @RoleIcon(role.RoleName)"></i>
                        @role.RoleName
                        <strong>@role.UserCount</strong>
                    </span>
                }
            </div>
        </div>
        <div class="sa-panel-body">
            <div class="sa-auth-table-wrap">
                <table class="table sa-table align-middle mb-0"
                       data-ejc-page-size="10"
                       data-ejc-search-placeholder="Search by email, role, branch, or compliance">
                    <thead>
                        <tr>
                            <th><i class="bi bi-envelope me-1"></i> Email</th>
                            <th><i class="bi bi-person-gear me-1"></i> Roles</th>
                            <th><i class="bi bi-geo-alt me-1"></i> Branch</th>
                            <th><i class="bi bi-check-circle me-1"></i> Compliance</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model.PrivilegedUsers)
                    {
                        <tr>
                            <td>
                                <div class="sa-user-email">@user.Email</div>
                            </td>
                            <td>
                                @{
                                    var roles = user.RolesSummary.Split(',', StringSplitOptions.TrimEntries);
                                }
                                <div class="sa-role-tags">
                                    @foreach (var r in roles)
                                    {
                                        <span class="sa-role-tag @RoleBadgeColor(r)">
                                            <i class="bi @RoleIcon(r)"></i> @r
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(user.BranchId))
                                {
                                    <span class="sa-branch-empty">—</span>
                                }
                                else
                                {
                                    <span class="sa-branch-label">
                                        <i class="bi bi-building"></i> @user.BranchId
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!user.RequiresBranch)
                                {
                                    <span class="sa-compliance sa-compliance-global">
                                        <i class="bi bi-globe2"></i> Global
                                    </span>
                                }
                                else if (user.MissingBranch)
                                {
                                    <span class="sa-compliance sa-compliance-danger">
                                        <i class="bi bi-x-circle-fill"></i> Missing Scope
                                    </span>
                                }
                                else
                                {
                                    <span class="sa-compliance sa-compliance-ok">
                                        <i class="bi bi-check-circle-fill"></i> Compliant
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Branch Coverage ── *@
    <div class="sa-section">
        <div class="sa-section-header">
            <div class="sa-section-title">
                <i class="bi bi-building"></i>
                <h2>Branch Coverage</h2>
            </div>
            <span class="sa-section-subtitle">Users scoped per branch</span>
        </div>
        <div class="sa-panel-body">
            @if (Model.BranchLoads.Count == 0)
            {
                <div class="sa-empty-state">
                    <i class="bi bi-diagram-3"></i>
                    <p>No branch scope assignments yet.</p>
                </div>
            }
            else
            {
                var maxBranchUsers = Math.Max(1, Model.BranchLoads.Max(b => b.UserCount));
                <div class="sa-branch-grid">
                    @foreach (var branch in Model.BranchLoads)
                    {
                        var pct = (double)branch.UserCount / maxBranchUsers * 100d;
                        <div class="sa-branch-card">
                            <div class="sa-branch-card-top">
                                <span class="sa-branch-card-id">
                                    <i class="bi bi-building"></i> @branch.BranchId
                                </span>
                                <strong class="sa-branch-card-count">@branch.UserCount</strong>
                            </div>
                            <div class="progress sa-branch-progress">
                                <div class="progress-bar" style="width: @pct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ── Two-Column: Churn Risk + AI Segments ── *@
    <div class="sa-two-col">
        <div class="sa-section">
            <div class="sa-section-header">
                <div class="sa-section-title">
                    <i class="bi bi-heartbreak"></i>
                    <h2>Churn Risk</h2>
                </div>
                <div class="sa-section-badges">
                    <span class="badge bg-danger">High @Model.HighChurnRiskCount</span>
                    <span class="badge bg-warning text-dark">Medium @Model.MediumChurnRiskCount</span>
                </div>
            </div>
            <div class="sa-panel-body sa-panel-body-table">
                <div class="sa-auth-table-wrap">
                    <table class="table sa-table align-middle mb-0" data-ejc-page-size="6">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Risk</th>
                                <th>Reasons</th>
                                <th>Last Payment</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.AtRiskMembers.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <div class="sa-empty-state-inline">
                                        <i class="bi bi-emoji-smile"></i>
                                        <span>No churn risk members right now</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var member in Model.AtRiskMembers)
                        {
                            <tr>
                                <td><span class="sa-user-email">@member.MemberEmail</span></td>
                                <td>
                                    <span class="badge @ChurnRiskBadgeClass(member.RiskLevel)">@member.RiskLevel</span>
                                    <div class="small text-muted">Score @member.RiskScore</div>
                                </td>
                                <td class="sa-cell-reason">@member.ReasonSummary</td>
                                <td>@(member.LastPaymentUtc?.ToLocalTime().ToString("MMM dd, yyyy") ?? "No payments")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="sa-section">
            <div class="sa-section-header">
                <div class="sa-section-title">
                    <i class="bi bi-pie-chart-fill"></i>
                    <h2>AI Segments</h2>
                </div>
                <span class="sa-section-subtitle">Member distribution</span>
            </div>
            <div class="sa-panel-body">
                @if (Model.MemberSegmentDistribution.Count == 0)
                {
                    <div class="sa-empty-state">
                        <i class="bi bi-robot"></i>
                        <p>No AI snapshots recorded yet.</p>
                    </div>
                }
                else
                {
                    var maxSegmentCount = Math.Max(1, Model.MemberSegmentDistribution.Max(i => i.MemberCount));
                    var totalSegmentMembers = Math.Max(1, Model.MemberSegmentDistribution.Sum(i => i.MemberCount));

                    <div class="sa-segment-list">
                    @foreach (var segment in Model.MemberSegmentDistribution)
                    {
                        var fillPercent = (double)segment.MemberCount / maxSegmentCount * 100d;
                        var sharePercent = (double)segment.MemberCount / totalSegmentMembers * 100d;

                        <div class="sa-segment-item">
                            <div class="sa-segment-info">
                                <span class="fw-semibold">@segment.SegmentLabel</span>
                                <span class="sa-segment-meta">@segment.MemberCount members · @sharePercent.ToString("0.#")%</span>
                            </div>
                            <div class="progress sa-segment-progress" role="img"
                                 aria-label="@segment.SegmentLabel segment share">
                                <div class="progress-bar" style="width: @fillPercent.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                            </div>
                        </div>
                    }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Two-Column: Retention Queue + Finance Alerts ── *@
    <div class="sa-two-col">
        <div class="sa-section">
            <div class="sa-section-header">
                <div class="sa-section-title">
                    <i class="bi bi-arrow-repeat"></i>
                    <h2>Retention Queue</h2>
                </div>
                <div class="sa-section-badges">
                    <span class="badge bg-primary">@Model.OpenRetentionActionCount open</span>
                </div>
            </div>
            <div class="sa-panel-body sa-panel-body-table">
                <div class="sa-auth-table-wrap">
                    <table class="table sa-table align-middle mb-0" data-ejc-paginate-disabled="true">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Segment</th>
                                <th>Status</th>
                                <th>Due</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.RetentionActions.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <div class="sa-empty-state-inline">
                                        <i class="bi bi-check-all"></i>
                                        <span>No open retention actions</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var action in Model.RetentionActions)
                        {
                            var isOverdue = action.DueDateUtc.HasValue && action.DueDateUtc.Value < Model.AsOfUtc;
                            <tr>
                                <td>
                                    <div class="sa-user-email">@action.MemberEmail</div>
                                    <div class="small text-muted">@action.ActionType</div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@action.SegmentLabel</span>
                                    <div class="small text-muted">@action.Reason</div>
                                </td>
                                <td>
                                    <span class="badge @RetentionStatusBadgeClass(action.Status)">@action.Status</span>
                                </td>
                                <td class="@(isOverdue ? "text-danger fw-semibold" : string.Empty)">
                                    @(action.DueDateUtc?.ToLocalTime().ToString("MMM dd, yyyy") ?? "—")
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="sa-panel-footer">
                <a class="btn btn-sm btn-outline-primary" asp-controller="MemberAccounts" asp-action="Index">
                    <i class="bi bi-arrow-right"></i> Open Member Accounts
                </a>
            </div>
        </div>

        <div class="sa-section">
            <div class="sa-section-header">
                <div class="sa-section-title">
                    <i class="bi bi-bell-fill"></i>
                    <h2>Finance Alerts</h2>
                </div>
                <span class="sa-section-subtitle">Latest signals</span>
            </div>
            <div class="sa-panel-body sa-panel-body-table">
                <div class="sa-auth-table-wrap">
                    <table class="table sa-table align-middle mb-0" data-ejc-page-size="6">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Type</th>
                                <th>Severity</th>
                                <th>State</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model.RecentAlerts.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <div class="sa-empty-state-inline">
                                        <i class="bi bi-check-circle"></i>
                                        <span>No finance alerts</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var alert in Model.RecentAlerts)
                        {
                            <tr>
                                <td class="text-nowrap">@alert.CreatedUtc.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                <td>@alert.AlertType</td>
                                <td><span class="badge @SeverityBadgeClass(alert.Severity)">@alert.Severity</span></td>
                                <td><span class="badge @StateBadgeClass(alert.State)">@alert.State</span></td>
                                <td class="sa-cell-reason">@alert.Message</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
