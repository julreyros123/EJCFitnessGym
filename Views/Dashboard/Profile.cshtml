@model EJCFitnessGym.Controllers.MemberProfileInputModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="container ejc-page">
    <div class="ejc-page-header">
        <div>
            <span class="ejc-eyebrow">Member Portal</span>
            <h1 class="display-5 mb-1">Complete Your Profile</h1>
            <p class="ejc-muted mb-0">Add your personal details so coaches and the front desk team can support you better.</p>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string status && !string.IsNullOrWhiteSpace(status))
    {
        <div class="alert alert-success mb-4">@status</div>
    }

    @if (TempData["MembershipStatusMessage"] is string membershipStatus && !string.IsNullOrWhiteSpace(membershipStatus))
    {
        var membershipStatusType = TempData["MembershipStatusType"] as string;
        var membershipAlertClass = (membershipStatusType ?? string.Empty).ToLowerInvariant() == "warning"
            ? "alert-warning"
            : "alert-success";
        <div class="alert @membershipAlertClass mb-4">@membershipStatus</div>
    }

    <div class="card ejc-profile-card">
        <div class="card-body p-4">
            <div class="ejc-profile-progress mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Profile Completion</h5>
                    <span class="ejc-profile-progress-value">@Model.CompletionPercent%</span>
                </div>
                <div class="progress">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @Model.CompletionPercent%" aria-valuenow="@Model.CompletionPercent" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>

            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="ejc-profile-photo-wrap">
                            @if (!string.IsNullOrWhiteSpace(Model.ExistingImagePath))
                            {
                                <img src="@Model.ExistingImagePath" alt="Profile photo" class="ejc-profile-photo" />
                            }
                            else
                            {
                                <div class="ejc-profile-avatar-fallback">No Photo</div>
                            }
                        </div>
                        <label asp-for="ProfileImage" class="form-label mt-3"></label>
                        <input asp-for="ProfileImage" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/*" />
                        <span asp-validation-for="ProfileImage" class="text-danger"></span>
                        <div class="form-text">Accepted formats: JPG, PNG, WEBP. Max size: 2 MB.</div>
                    </div>

                    <div class="col-lg-8">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input value="@Model.Email" class="form-control" readonly />
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Age" class="form-label"></label>
                                <input asp-for="Age" class="form-control" />
                                <span asp-validation-for="Age" class="text-danger"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="HeightCm" class="form-label"></label>
                                <input asp-for="HeightCm" class="form-control" />
                                <span asp-validation-for="HeightCm" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="WeightKg" class="form-label"></label>
                                <input asp-for="WeightKg" class="form-control" />
                                <span asp-validation-for="WeightKg" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Bmi" class="form-label"></label>
                                <input asp-for="Bmi" class="form-control" readonly />
                                <span asp-validation-for="Bmi" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary">Save Profile</button>
                            <a asp-action="Member" class="btn btn-outline-light">Back to Portal</a>
                            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary">Account Security</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card ejc-profile-card mt-4" id="membership-settings">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">Membership Settings</h5>
                    <p class="ejc-muted mb-0">Manage cancellation requests from settings with a required reason.</p>
                </div>
                <span class="badge @Model.MembershipStatusBadgeClass">@Model.MembershipStatusLabel</span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Current plan</label>
                    <input value="@Model.CurrentPlanName" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cancellation request</label>
                    <input value="@(Model.HasOpenCancellationRequest ? "Pending review" : "No open request")" class="form-control" readonly />
                </div>
            </div>

            @if (Model.HasOpenCancellationRequest)
            {
                <div class="alert alert-info mb-0">
                    <div class="fw-semibold mb-1">Cancellation already submitted</div>
                    <div class="small">Requested: @(Model.OpenCancellationRequestedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Unknown")</div>
                    @if (!string.IsNullOrWhiteSpace(Model.OpenCancellationReason))
                    {
                        <div class="small mt-1">Reason: @Model.OpenCancellationReason</div>
                    }
                </div>
            }
            else
            {
                <form asp-action="RequestMembershipCancellation" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="CancellationReason" class="form-label"></label>
                        <textarea asp-for="CancellationReason" class="form-control" rows="4" maxlength="300" placeholder="State your reason for cancellation (minimum 15 characters)."></textarea>
                        <span asp-validation-for="CancellationReason" class="text-danger"></span>
                        <div class="form-text">Your request is reviewed by staff before membership cancellation is finalized.</div>
                    </div>
                    <button type="submit" class="btn btn-outline-danger">Submit Cancellation Request</button>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const heightInput = document.getElementById('HeightCm');
            const weightInput = document.getElementById('WeightKg');
            const bmiInput = document.getElementById('Bmi');

            if (!heightInput || !weightInput || !bmiInput) {
                return;
            }

            function parseValue(value) {
                if (!value) return NaN;
                return parseFloat(value.toString().replace(',', '.'));
            }

            function computeBmi() {
                const heightCm = parseValue(heightInput.value);
                const weightKg = parseValue(weightInput.value);
                if (!Number.isFinite(heightCm) || !Number.isFinite(weightKg) || heightCm <= 0 || weightKg <= 0) {
                    bmiInput.value = '';
                    return;
                }

                const heightM = heightCm / 100;
                const bmi = weightKg / (heightM * heightM);
                bmiInput.value = bmi.toFixed(2);
            }

            heightInput.addEventListener('input', computeBmi);
            weightInput.addEventListener('input', computeBmi);
            computeBmi();
        })();
    </script>
}
