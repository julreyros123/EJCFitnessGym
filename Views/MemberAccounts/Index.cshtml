@model EJCFitnessGym.Models.Admin.MemberAccountIndexViewModel
@{
    ViewData["Title"] = "Members";
    var members = Model?.Members?.ToList() ?? new List<EJCFitnessGym.Models.Admin.MemberAccountListItemViewModel>();
    var canCreateMember = User.IsInRole("SuperAdmin");
}

<div class="py-4 ejc-member-accounts-page">
    <div class="ejc-table-toolbar mb-3">
        <div>
            <h1 class="h3 mb-0">Member Accounts</h1>
            @if (User.IsInRole("SuperAdmin"))
            {
                <p class="ejc-muted mb-0">SuperAdmin can create member accounts and review all branch membership records.</p>
            }
            else if (User.IsInRole("Admin") || User.IsInRole("Finance"))
            {
                <p class="ejc-muted mb-0">Admin and Finance can manage existing member plans within branch scope.</p>
            }
            else
            {
                <p class="ejc-muted mb-0">Create and manage member accounts with membership plan assignment.</p>
            }
        </div>
        @if (canCreateMember)
        {
            <a class="btn btn-primary" asp-action="Create">Create Member</a>
        }
    </div>

    @if (TempData["StatusMessage"] is string status && !string.IsNullOrWhiteSpace(status))
    {
        <div class="alert alert-info">@status</div>
    }

        <div class="card ejc-users-card">
        <div class="card-header d-flex align-items-center justify-content-between gap-2">
            <h5 class="mb-0">Member List</h5>
            <span class="text-muted small ejc-users-summary">Total members: @members.Count</span>
        </div>
        <div class="card-body p-0 ejc-table-shell-host">
            <div class="table-responsive ejc-table-shell ejc-users-table-shell">
                <table
                    class="table table-striped table-hover align-middle mb-0 ejc-users-table"
                    data-ejc-page-size="12"
                    data-ejc-search-placeholder="Search members by name, email, phone, plan, status">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Home Branch</th>
                            <th>Plan</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (members.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">No members found.</td>
                        </tr>
                    }
                    @foreach (var member in members)
                    {
                        <tr class="ejc-users-row-clickable"
                            data-row-href="@Url.Action("Details", new { id = member.UserId })"
                            tabindex="0"
                            role="link"
                            aria-label="View @member.FullName details">
                            <td>
                                <span class="ejc-users-text-truncate" title="@member.FullName">@member.FullName</span>
                            </td>
                            <td>
                                <span class="ejc-users-text-truncate ejc-users-email" title="@member.Email">@member.Email</span>
                            </td>
                            <td class="text-nowrap">
                                @{
                                    var phoneText = string.IsNullOrWhiteSpace(member.PhoneNumber) ? "-" : member.PhoneNumber;
                                }
                                <span class="ejc-users-text-truncate ejc-users-phone" title="@phoneText">@phoneText</span>
                            </td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(member.HomeBranchDisplayName))
                                {
                                    <span class="badge bg-warning text-dark">No Home Branch</span>
                                }
                                else
                                {
                                    <div class="ejc-users-text-truncate" title="@member.HomeBranchDisplayName">@member.HomeBranchDisplayName</div>
                                    <div class="small text-muted">@member.HomeBranchId</div>
                                }
                            </td>
                            <td class="text-nowrap">
                                <span class="ejc-users-text-truncate ejc-users-plan" title="@member.PlanName">@member.PlanName</span>
                            </td>
                            <td>@(member.StartDateUtc?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>@(member.EndDateUtc?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>
                                <span class="badge @(member.IsMembershipActive ? "text-bg-success" : "text-bg-secondary")">
                                    @(member.IsMembershipActive ? "Active" : "Inactive")
                                </span>
                                <div class="small text-muted mt-1">@((member.SubscriptionStatus?.ToString()) ?? "None")</div>
                            </td>
                            <td class="text-end text-nowrap ejc-users-actions-cell">
                                <div class="ejc-users-actions">
                                    <a class="btn btn-sm btn-outline-secondary"
                                       data-row-action
                                       asp-action="Details"
                                       asp-route-id="@member.UserId">View</a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const rows = document.querySelectorAll(".ejc-users-row-clickable[data-row-href]");
            if (!rows.length) {
                return;
            }

            const canNavigate = (event) => {
                if (!event) {
                    return true;
                }

                const target = event.target;
                if (!(target instanceof HTMLElement)) {
                    return true;
                }

                return !target.closest("a, button, input, select, textarea, label, [data-row-action]");
            };

            rows.forEach((row) => {
                row.addEventListener("click", (event) => {
                    if (!canNavigate(event)) {
                        return;
                    }

                    const href = row.getAttribute("data-row-href");
                    if (!href) {
                        return;
                    }

                    window.location.href = href;
                });

                row.addEventListener("keydown", (event) => {
                    if (event.key !== "Enter" && event.key !== " ") {
                        return;
                    }

                    if (!canNavigate(event)) {
                        return;
                    }

                    event.preventDefault();
                    const href = row.getAttribute("data-row-href");
                    if (href) {
                        window.location.href = href;
                    }
                });
            });
        })();
    </script>
}
