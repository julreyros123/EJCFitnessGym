@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Verify Email";
}

<section class="ejc-auth ejc-auth-register">
    <div class="ejc-auth-card">
        <div class="ejc-auth-form">
            <div class="ejc-auth-brand">
                <div>
                    <span class="ejc-eyebrow">Account Verification</span>
                    <h1 class="h2 mb-1">Enter verification code</h1>
                    <p class="ejc-muted mb-0">We sent a 6-digit verification code to <strong>@Model.Email</strong>.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-info">@Model.StatusMessage</div>
            }

            <p class="ejc-muted">
                Verify your email to activate secure member access and finish onboarding.
            </p>

            @if (!Model.IsVerified)
            {
                <form method="post" asp-page-handler="Verify">
                    <input type="hidden" name="email" value="@Model.Email" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger ejc-auth-validation"></div>
                    <div class="form-floating mb-3 ejc-auth-input">
                        <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" inputmode="numeric" maxlength="6" placeholder="123456" />
                        <label asp-for="Input.Code">6-digit verification code</label>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 ejc-auth-submit">Verify email</button>
                </form>
            }

            <div class="d-grid gap-2 mt-3">
                <a class="btn btn-outline-light" asp-page="./ResendEmailConfirmation" asp-route-email="@Model.Email">Resend verification code</a>
                <a class="btn btn-outline-light" asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Go to sign in</a>
            </div>
        </div>

        <div class="ejc-auth-aside">
            <span class="ejc-eyebrow">Security</span>
            <h2 class="h3 mt-2">Verified member identity</h2>
            <p class="ejc-muted">Email verification protects member billing and account recovery workflows.</p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
